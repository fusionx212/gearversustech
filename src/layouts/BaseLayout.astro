---
import '../styles/global.css';
import '../styles/product-images.css';
import HealthCheck from '../components/HealthCheck.astro';

export interface Props {
  title: string;
  description: string;
  schema?: string;
}

const { title, description, schema } = Astro.props;
const pageTitle = title === 'Gear Versus Tech' ? title : `${title} \u00b7 Gear Versus Tech`;
---

<!doctype html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:site_name" content="Gear Versus Tech" />
  <link rel="canonical" href={Astro.url.href} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@500;700&family=Source+Sans+3:wght@400;600&family=Space+Grotesk:wght@600;700&display=swap"
    rel="stylesheet"
  />
  {schema && <script type="application/ld+json" set:html={schema}></script>}
  <!-- Cloudflare Web Analytics -->
  <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "REPLACE_WITH_CF_TOKEN"}'></script>
</head>
<body>
  <HealthCheck />
  <header class="site-header" id="site-header">
    <div class="header-inner">
      <a href="/" class="logo">Gear<span>Versus</span>Tech</a>
      <nav class="nav-links" aria-label="Primary">
        <a href="/spaces/" class={Astro.url.pathname.startsWith('/spaces') ? 'active' : ''}>Spaces</a>
        <a href="/gaming/" class={Astro.url.pathname.startsWith('/gaming') ? 'active' : ''}>Gaming</a>
        <a href="/home-gym/" class={Astro.url.pathname.startsWith('/home-gym') ? 'active' : ''}>Home Gym</a>
        <a href="/smart-home/" class={Astro.url.pathname.startsWith('/smart-home') ? 'active' : ''}>Smart Home</a>
        <a href="/deals/" class={Astro.url.pathname.startsWith('/deals') ? 'active' : ''}>Deals</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <p class="footer-brand">Gear Versus Tech</p>
      <p class="footer-tagline">We compare. You choose. Buy smarter.</p>
      <div class="footer-links">
        <a href="/">Home</a>
        <a href="/spaces/">Spaces</a>
        <a href="/gaming/">Gaming</a>
        <a href="/home-gym/">Home Gym</a>
        <a href="/smart-home/">Smart Home</a>
        <a href="/best/">Best Picks</a>
        <a href="/deals/">Deals</a>
        <a href="/contact/">Contact</a>
        <a href="/privacy/">Privacy</a>
        <a href="/disclosure/">Disclosure</a>
        <a href="/methodology/">How We Test</a>
      </div>
      <p class="contact-email">
        <a href="mailto:hello@gearversustech.com">hello@gearversustech.com</a>
      </p>
      <p class="disclaimer">
        As an Amazon Associate, eBay Partner, and Awin affiliate, we earn from qualifying purchases.
        Our comparisons are based on testing and data, not commission rates.
        Prices are checked regularly but may change. Always confirm on the retailer's site.
      </p>
    </div>
  </footer>
</body>
</html>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduceMotion) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          gsap.to(entry.target, { opacity: 1, y: 0, duration: 0.45, ease: 'power2.out' });
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -20px 0px' });

    document.querySelectorAll('.compare-row, .space-band, .vs-product, .faq-item, .verdict, .also-card').forEach(el => {
      const element = el as HTMLElement;
      gsap.set(element, { opacity: 0, y: 12 });
      observer.observe(element);
    });
  }

  const winnerBadge = document.querySelector('.vs-product.winner .vs-badge');
  if (winnerBadge && !reduceMotion) {
    gsap.fromTo(winnerBadge, { opacity: 0 }, { opacity: 1, duration: 0.35, delay: 0.05, ease: 'power2.out' });
  }
</script>
