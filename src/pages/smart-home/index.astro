---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryClusterList from '../../components/CategoryClusterList.astro';
import { getArticlesByCategory, attachWinnerImages } from '../../lib/supabase';

const articlesRaw = await getArticlesByCategory('smart-home', 40);
const articles = await attachWinnerImages(articlesRaw);
---

<BaseLayout
  title="Smart Home Comparisons"
  description="Head-to-head UK smart home comparisons — hubs, sensors, lights, locks, thermostats. Matter, Zigbee, Thread."
>

<section class="hub-hero">
  <div class="container-wide">
    <p class="hub-kicker">Smart home</p>
    <h1>Smart home comparisons</h1>
    <p>Hubs, sensors, lights, locks. Compared head-to-head so you buy the right device the first time — not a lifestyle gallery.</p>
  </div>
</section>

<CategoryClusterList
  articles={articles}
  emptyHtml="<p>Smart home comparisons coming soon.</p>"
/>
</BaseLayout>
