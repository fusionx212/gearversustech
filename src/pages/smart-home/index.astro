---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Smart Home Comparisons";
const description = "Data-dense comparisons of smart home hubs, sensors, lights, doorbells, thermostats, and locks. Matter, Zigbee, Z-Wave, Thread -- tested side by side so you buy once and buy right.";
---

<BaseLayout title={title} description={description}>
<div class="container">

  <section class="cat-header">
    <h1>Smart Home Comparisons</h1>
    <p>Hubs, sensors, lights, locks, thermostats. Matter, Zigbee, Z-Wave, Thread -- tested head-to-head so you buy the right device the first time.</p>
  </section>

  <div class="grid-2">
    <a href="/smart-home/homey-pro-vs-aqara-hub-m3/" class="card">
      <div class="card-cat">Smart Home Hubs</div>
      <div class="card-title">Homey Pro vs Aqara Hub M3</div>
      <div class="card-desc">Eight protocols vs four. 50K devices vs 128. We determine which local-first hub earns the desk space.</div>
      <div class="card-meta"><span class="rating">9.2</span> <span class="sep">vs</span> <span class="rating">8.1</span> <span class="winner">Winner: Homey Pro</span></div>
    </a>

    <a href="/smart-home/philips-hue-vs-govee-gaming-lights/" class="card">
      <div class="card-cat">Smart Lighting</div>
      <div class="card-title">Philips Hue Play vs Govee Gaming Lights</div>
      <div class="card-desc">Premium HDMI sync box versus budget LED light strips. We measure latency, brightness, and colour accuracy.</div>
      <div class="card-meta">Coming soon</div>
    </a>

    <a href="/smart-home/ring-vs-eufy-doorbell/" class="card">
      <div class="card-cat">Smart Security</div>
      <div class="card-title">Ring Video Doorbell vs Eufy Security</div>
      <div class="card-desc">Subscription storage versus local. 1080p versus 2K. Two market leaders tested for UK homes.</div>
      <div class="card-meta">Coming soon</div>
    </a>

    <a href="/smart-home/nest-vs-hive-thermostat/" class="card">
      <div class="card-cat">Smart Heating</div>
      <div class="card-title">Google Nest vs Hive Thermostat</div>
      <div class="card-desc">Learning algorithms versus simple scheduling. Which saves more on UK energy bills? Real data, not marketing claims.</div>
      <div class="card-meta">Coming soon</div>
    </a>

    <a href="/smart-home/smartthings-vs-home-assistant/" class="card">
      <div class="card-cat">Smart Home Hubs</div>
      <div class="card-title">Samsung SmartThings vs Home Assistant</div>
      <div class="card-desc">Consumer-friendly hub meets open-source powerhouse. Which fits your technical skill level?</div>
      <div class="card-meta">Coming soon</div>
    </a>

    <a href="/best/best-smart-home-hubs/" class="card">
      <div class="card-cat">Best Picks</div>
      <div class="card-title">Best Smart Home Hubs 2026: UK Buyer's Guide</div>
      <div class="card-desc">Homey Pro, Aqara M3, SmartThings, Home Assistant. We rank every hub by protocol count, ease of use, and price.</div>
      <div class="card-meta">Coming soon</div>
    </a>
  </div>
</div>
</BaseLayout>
