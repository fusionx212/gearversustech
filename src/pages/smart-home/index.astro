---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getArticlesByCategory } from '../../lib/supabase';

const articles = await getArticlesByCategory('smart-home', 12);
---

<BaseLayout title="Smart Home Comparisons" description="Data-dense comparisons of smart home hubs, sensors, lights, doorbells, thermostats, and locks.">
<div class="container">
  <section class="cat-header">
    <h1>Smart Home Comparisons</h1>
    <p>Hubs, sensors, lights, locks, thermostats. Matter, Zigbee, Z-Wave, Thread -- tested head-to-head so you buy the right device the first time.</p>
  </section>

  <div class="grid-2">
    {articles.map(a => (
      <a href={`/smart-home/compare/${a.slug}/`} class="card">
        <div class="card-cat">{a.subcategory || 'Smart Home'}</div>
        <div class="card-title">{a.title}</div>
        <div class="card-desc">{a.description}</div>
        <div class="card-meta">
          {a.winner_name && <span class="winner">Winner: {a.winner_name}</span>}
          {a.winner_rating && <span class="rating">{a.winner_rating}</span>}
        </div>
      </a>
    ))}
  </div>
</div>
</BaseLayout>
