---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getArticlesByCategory, attachWinnerImages } from '../../lib/supabase';

const articlesRaw = await getArticlesByCategory('best', 12);
const articles = await attachWinnerImages(articlesRaw);
---

<BaseLayout title="Best Picks and Roundups" description="Curated best-of roundups for smart home and gaming gear.">
<div class="container">
  <section class="cat-header">
    <h1>Best Picks and Roundups</h1>
    <p>Curated rankings across Smart Home and Gaming. Every product tested. Every list updated monthly.</p>
  </section>

  <div class="grid-2">
    {articles.length > 0 ? articles.map(a => (
      <a href={`/best/compare/${a.slug}/`} class="card">
        {a.winnerImage && (
          <div class="card-image-wrap">
            <img class="card-image" src={a.winnerImage} alt={a.winner_name ?? a.title} loading="lazy" />
          </div>
        )}
        <div class="card-cat">{a.subcategory || 'Best in Class'}</div>
        <div class="card-title">{a.title}</div>
        <div class="card-desc">{a.description}</div>
        <div class="card-meta">
          {a.winner_name && <span class="winner">Winner: {a.winner_name}</span>}
        </div>
      </a>
    )) : (
      <div class="card" style="grid-column:1/-1;text-align:center;padding:3rem;">
        <p style="color:var(--text-muted);">Best-in-class roundups coming soon.</p>
      </div>
    )}
  </div>
</div>
</BaseLayout>
