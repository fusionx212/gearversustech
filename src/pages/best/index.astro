---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryClusterList from '../../components/CategoryClusterList.astro';
import { getArticlesByCategory, attachWinnerImages } from '../../lib/supabase';

const articlesRaw = await getArticlesByCategory('best', 40);
const articles = await attachWinnerImages(articlesRaw);
---

<BaseLayout
  title="Best Picks and Under-£Y Roundups"
  description="Best-of and best-under-£Y UK tech roundups — category winners with live buy boxes."
>

<section class="hub-hero">
  <div class="container-wide">
    <p class="hub-kicker">Best / under £Y</p>
    <h1>Best picks and under-£ roundups</h1>
    <p>Category winners and budget bands. Same scoring as our A vs B pages — ranked for UK shoppers.</p>
  </div>
</section>

<CategoryClusterList
  articles={articles}
  emptyHtml="<p>Best-in-class roundups coming soon.</p>"
/>
</BaseLayout>
