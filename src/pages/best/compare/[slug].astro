---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CompareShell from '../../../components/CompareShell.astro';
import {
  getArticle,
  getArticleProducts,
  getComparedProducts,
  getRelatedArticles,
} from '../../../lib/supabase';
import { buildCompareSchema } from '../../../lib/compare-schema';

export const prerender = false;

const { slug } = Astro.params;
const article = await getArticle(slug as string);
if (!article) return new Response('Article not found', { status: 404 });

const { winner, runnerup } = await getArticleProducts(article);
const alsoCompared = await getComparedProducts(
  article.content_html,
  [article.winner_name, article.runnerup_name].filter(Boolean) as string[]
);
const related = await getRelatedArticles(article.category, article.subcategory, article.slug, 6);
const pageUrl = `https://gearversustech.com/${article.category}/compare/${slug}/`;
const schema = buildCompareSchema({
  title: article.title,
  description: article.description,
  pageUrl,
  createdAt: article.created_at,
  updatedAt: article.updated_at,
  winnerName: article.winner_name,
  winnerRating: article.winner_rating,
  runnerupName: article.runnerup_name,
  runnerupRating: article.runnerup_rating,
  winner,
  runnerup,
});

const isGym = /gym|garage|rack|floor/i.test(
  `${article.subcategory || ''} ${article.title}`
);
---

<BaseLayout title={article.title} description={article.description} schema={schema}>
  <CompareShell
    title={article.title}
    description={article.description}
    category={article.category}
    subcategory={article.subcategory}
    contentHtml={article.content_html}
    updatedAt={article.updated_at}
    winnerName={article.winner_name}
    winnerRating={article.winner_rating}
    runnerupName={article.runnerup_name}
    runnerupRating={article.runnerup_rating}
    winner={winner}
    runnerup={runnerup}
    alsoCompared={alsoCompared}
    related={related}
    kitTitle={isGym ? 'UK Garage Gym Build Kit' : 'Want the decided cart?'}
    kitBlurb={
      isGym
        ? 'Ceiling constraints, rack/flooring picks, noise notes, and a verified UK cart.'
        : 'Optional build kits for when a compare is done and you just want the shopping list.'
    }
    kitLabel={isGym ? 'Get the Garage Gym Kit — £19' : undefined}
  />
</BaseLayout>
