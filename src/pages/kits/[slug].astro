---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import { getKitUrl } from '../../lib/kit';
import {
  getKit,
  getKitItems,
  attachKitItemProducts,
  getKits,
  catalogueImage,
} from '../../lib/supabase';

export const prerender = false;

const { slug } = Astro.params;
if (!slug) {
  return new Response('Not found', { status: 404 });
}

const kit = await getKit(slug);
if (!kit) {
  // Fallback: list known slugs for static tooling
  const all = await getKits();
  if (!all.find((k) => k.slug === slug)) {
    return new Response('Kit not found', { status: 404 });
  }
}

const items = kit ? await attachKitItemProducts(await getKitItems(kit.slug)) : [];
const tiers = kit?.tier_labels || [];
const buyUrl = kit?.stripe_payment_link || getKitUrl(kit?.slug);
const mockupRaw = kit?.kit_mockup_url || kit?.hero_image_url;
const isGamingRoom = slug === 'gaming-room-build-kit';
/** Bump when replacing the room plate so CDN/browsers drop the old collage. */
const GAMING_ROOM_PLATE_V = '20260716room2';
const mockup =
  isGamingRoom && mockupRaw
    ? `${mockupRaw.split('?')[0]}?v=${GAMING_ROOM_PLATE_V}`
    : mockupRaw;

function tierItems(tierId: string) {
  return items.filter((i) => i.tier === tierId);
}

function productPhoto(item: (typeof items)[0]) {
  return catalogueImage(item.link_key, item.product?.image_url || null) || null;
}

function scoreOf(item: (typeof items)[0]) {
  return item.score_out_of_10 ?? item.product?.score_out_of_10 ?? null;
}

function isPcLine(item: (typeof items)[0]) {
  return /gaming pc|prebuilt|laptop/i.test(item.product_name || '');
}

function tierAnchorPc(tierId: string) {
  return tierItems(tierId).find(isPcLine) || tierItems(tierId)[0];
}
---

{kit && (
  <BaseLayout title={kit.name} description={kit.description}>
    <article class="container kit-detail">
      <nav class="breadcrumb">
        <a href="/">Home</a> /
        <a href="/kits/">Kits</a> /
        <span class="current">{kit.name}</span>
      </nav>

      <header class={`kit-detail-hero${isGamingRoom ? ' kit-detail-hero--room' : ''}`}>
        <div class="kit-detail-copy">
          <p class="kit-kicker">Digital kit · £{kit.price_gbp}</p>
          <h1>{kit.name}</h1>
          <p class="lede">{kit.description}</p>
          <div class="kit-actions">
            {buyUrl ? (
              <a class="btn btn-kit" href={buyUrl} rel="noopener">
                Buy kit — £{kit.price_gbp}
              </a>
            ) : (
              <a class="btn btn-kit" href="/contact/?interest=kit">Buy kit (link soon)</a>
            )}
            <a class="btn btn-ghost" href="#tiers">See PC tiers</a>
            {kit.compare_hub_href && (
              <a class="btn btn-ghost" href={kit.compare_hub_href}>Browse free compares</a>
            )}
          </div>
        </div>
        {mockup && (
          <figure class="kit-detail-mockup">
            <img
              src={mockup}
              alt={
                isGamingRoom
                  ? `${kit.name} — cinematic full gaming room (lifestyle plate)`
                  : `${kit.name} — kit staged in-room`
              }
              width="1800"
              height="1050"
              fetchpriority="high"
            />
            <figcaption>
              {isGamingRoom
                ? 'Lifestyle full-room plate (ComfyUI) — furniture, lighting, and desk in one scene, not clipped product stickers. Exact SKUs and affiliate carts live in the tiers below.'
                : 'Full kit-in-room mockup from verified product photos.'}
            </figcaption>
          </figure>
        )}
      </header>

      <section class="kit-tiers kit-tiers--primary" id="tiers">
        <h2>{isGamingRoom ? 'Budget tiers (PC included)' : "What's in the pack"}</h2>
        <p class="kit-tiers-lede">
          {isGamingRoom
            ? 'Each tier is a complete room cart: prebuilt gaming PC (Amazon UK + eBay UK) plus desk, monitor, keyboard, mouse, headset — chair from Solid up. Grades are honest.'
            : 'Every line item below is part of the decided cart. Grades are honest — some starter picks are deliberately mid-7s.'}
        </p>

        {isGamingRoom && (
          <div class="kit-tier-summary">
            {tiers.map((t) => {
              const pc = tierAnchorPc(t.id);
              if (!pc) return null;
              return (
                <a class="kit-tier-summary-card" href={`#tier-${t.id}`}>
                  <span class="kit-tier-summary-label">{t.label}</span>
                  <span class="kit-tier-summary-budget">{t.budget}</span>
                  <strong>{pc.product_name}</strong>
                  <span class="kit-tier-summary-blurb">{t.blurb}</span>
                </a>
              );
            })}
          </div>
        )}

        {tiers.map((t) => {
          const list = tierItems(t.id);
          if (!list.length) return null;
          return (
            <div class="kit-tier-block" id={`tier-${t.id}`}>
              <header class="kit-tier-head">
                <h3>{t.label} <span class="tier-budget">{t.budget}</span></h3>
                <p>{t.blurb}</p>
              </header>
              <div class="kit-item-grid">
                {list.map((item) => {
                  const photo = productPhoto(item);
                  const score = scoreOf(item);
                  const pc = isPcLine(item);
                  return (
                    <article class={`kit-item-card${pc ? ' kit-item-card--pc' : ''}`}>
                      <div class="kit-item-photo">
                        {photo ? (
                          <img src={photo} alt={item.product_name} width="200" height="200" loading="lazy" />
                        ) : (
                          <span class="kit-item-photo-empty">Photo pending verified ASIN</span>
                        )}
                      </div>
                      <div class="kit-item-body">
                        <h4>
                          {pc && <span class="kit-pc-badge">PC</span>}
                          {item.product_name}
                        </h4>
                        {score != null && (
                          <p class="kit-item-score">{score}/10</p>
                        )}
                        {item.why_in_kit && <p class="kit-item-why">{item.why_in_kit}</p>}
                        {item.product?.review_summary && (
                          <p class="kit-item-review"><strong>Reviews:</strong> {item.product.review_summary}</p>
                        )}
                        <div class="kit-item-links">
                          {item.compare_href && (
                            <a href={item.compare_href}>Compare spoke →</a>
                          )}
                          {item.link_key && item.product?.amazon_asin && (
                            <a href={`/c/amazon/${item.link_key}`} rel="nofollow sponsored">Amazon UK</a>
                          )}
                          {item.link_key && (
                            <a href={`/c/ebay/${item.link_key}`} rel="nofollow sponsored">eBay UK</a>
                          )}
                        </div>
                      </div>
                    </article>
                  );
                })}
              </div>
            </div>
          );
        })}
      </section>

      <section class="kit-who">
        <div>
          <h2>Who it's for</h2>
          <ul>
            {(kit.who_for || []).map((x) => <li>{x}</li>)}
          </ul>
        </div>
        <div>
          <h2>Who it's not for</h2>
          <ul>
            {(kit.who_not_for || []).map((x) => <li>{x}</li>)}
          </ul>
        </div>
      </section>

      {kit.honest_take && (
        <section class="kit-honest">
          <h2>Honest take</h2>
          <p>{kit.honest_take}</p>
        </section>
      )}

      {kit.review_summary && (
        <section class="kit-reviews">
          <h2>Kit-level review synthesis</h2>
          <p>{kit.review_summary}</p>
        </section>
      )}

      {kit.setup_notes && (
        <section class="kit-setup">
          <h2>Setup notes</h2>
          <p>{kit.setup_notes}</p>
        </section>
      )}

      {(slug === 'gaming-room-build-kit' ||
        slug === 'uk-garage-gym-build-kit' ||
        slug === 'shed-garden-office-setup-pack' ||
        slug === 'shed-gym-setup-pack') && (
        <section class="kit-setup kit-sheds">
          <h2>Shell compares (by use-case)</h2>
          <p>
            Hub with Gaming / Gym / Man cave / Office / Summer house journeys:
            <a href="/best/garden-sheds/">Garden space fitting hub</a>.
          </p>
          <ul class="kit-shed-links">
            {slug.includes('gym') ? (
              <>
                <li><a href="/best/compare/shed-gym-fit-journey-uk/">Shed gym fit journey</a></li>
                <li><a href="/best/compare/best-shed-for-home-gym-uk/">Best shed for home gym</a></li>
                <li><a href="/best/compare/summerhouse-seasonal-vs-year-round-uk/">Seasonal vs year-round</a></li>
              </>
            ) : (
              <>
                <li><a href="/best/compare/gaming-shed-fit-journey-uk/">Gaming shed fit journey</a></li>
                <li><a href="/best/compare/desk-size-for-garden-shed-uk/">Desk size vs shed band</a></li>
                <li><a href="/best/compare/garden-office-fit-journey-uk/">Garden office journey</a></li>
                <li><a href="/best/compare/man-cave-shed-fit-journey-uk/">Man cave journey</a></li>
              </>
            )}
          </ul>
        </section>
      )}

      <div class="kit-bottom-cta">
        {buyUrl ? (
          <a class="btn btn-kit" href={buyUrl} rel="noopener">
            Get {kit.name} — £{kit.price_gbp}
          </a>
        ) : null}
        <a class="btn btn-ghost" href="#tiers">Back to PC tiers</a>
        <a class="btn btn-ghost" href="/kits/">All kits</a>
      </div>

      <EmailCapture />
    </article>
  </BaseLayout>
)}
