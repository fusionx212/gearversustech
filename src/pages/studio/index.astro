---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';

const sampleImage = '/images/kits/gaming-room-build-kit.png';
const spaces = [
  { value: 'gaming-room', label: 'Gaming room', note: 'Screens, desk depth, lighting and cable routes' },
  { value: 'man-cave', label: 'Man cave', note: 'Comfort, entertainment, storage and atmosphere' },
  { value: 'garden-office', label: 'Garden office', note: 'A productive room with power, light and comfort' },
  { value: 'shed-gym', label: 'Shed gym', note: 'Clearance, flooring, equipment and movement' },
];
const modes = [
  { value: 'style', label: 'Style this room', note: 'Preserve the architecture and change the look.' },
  { value: 'fill', label: 'Fill the space', note: 'Start with an empty or unfinished room.' },
  { value: 'reimagine', label: 'Reimagine it', note: 'Give the concept more creative freedom.' },
];
const styles = ['Dark studio', 'Warm industrial', 'Clean minimal', 'Retro arcade', 'Quiet luxury', 'Natural workspace'];
---

<BaseLayout title="GVT Studio" description="Visualise a gaming room, man cave, garden office or shed gym, then compare the real gear needed to build it.">
  <main class="studio-page">
    <section class="studio-intro" aria-labelledby="studio-title">
      <div>
        <p class="gvt-eyebrow">GVT / Studio 01</p>
        <h1 id="studio-title">See the room<br /><em>before you buy.</em></h1>
      </div>
      <div class="studio-intro-copy">
        <p>Upload your space, choose the direction and get an AI concept built around how you actually want to use it.</p>
        <span class="studio-intro-rule">Then we connect the look to real comparisons, kits and UK buying options.</span>
      </div>
    </section>

    <section class="studio-workbench" aria-label="GVT Studio room visualiser">
      <aside class="studio-controls">
        <div class="studio-step"><span>01</span><strong>Define the space</strong></div>
        <form id="studio-form">
          <fieldset>
            <legend>What are you building?</legend>
            <div class="studio-choice-grid">
              {spaces.map((space, index) => (
                <label class:list={['studio-choice', index === 0 && 'is-selected']}>
                  <input type="radio" name="space" value={space.value} checked={index === 0} />
                  <span><strong>{space.label}</strong><small>{space.note}</small></span>
                </label>
              ))}
            </div>
          </fieldset>

          <div class="studio-step studio-step-spaced"><span>02</span><strong>Choose the intervention</strong></div>
          <fieldset>
            <legend class="sr-only">AI intervention mode</legend>
            <div class="studio-mode-list">
              {modes.map((mode, index) => (
                <label class:list={['studio-mode', index === 0 && 'is-selected']}>
                  <input type="radio" name="mode" value={mode.value} checked={index === 0} />
                  <span><strong>{mode.label}</strong><small>{mode.note}</small></span>
                  <i aria-hidden="true">{String(index + 1).padStart(2, '0')}</i>
                </label>
              ))}
            </div>
          </fieldset>

          <div class="studio-field-row">
            <label class="studio-field"><span>Style direction</span><select name="style">{styles.map((style) => <option value={style}>{style}</option>)}</select></label>
            <label class="studio-field"><span>Working budget</span><select name="budget"><option value="under-500">Under £500</option><option value="500-1000">£500–£1,000</option><option value="1000-2500">£1,000–£2,500</option><option value="2500-plus">£2,500+</option></select></label>
          </div>

          <label class="studio-field"><span>Keep, remove or prioritise</span><textarea name="instructions" rows="3" maxlength="420" placeholder="Keep my window and existing desk. Prioritise comfortable long sessions and hidden cable routes."></textarea></label>

          <div class="studio-upload">
            <label class="studio-upload-label" for="studio-image"><span class="studio-upload-icon" aria-hidden="true">+</span><span><strong>Upload a photo of your space</strong><small>JPG, PNG or WebP · up to 8MB</small></span></label>
            <input id="studio-image" name="image" type="file" accept="image/jpeg,image/png,image/webp" />
            <button class="studio-sample" type="button" data-use-sample>Use the sample gaming room</button>
          </div>

          <button class="studio-submit" type="submit"><span data-submit-label>Generate my concept</span><span aria-hidden="true">↗</span></button>
          <p class="studio-form-note">Your image is sent to the image provider only when you generate. GVT concepts are visual guidance, not dimensioned plans.</p>
        </form>
      </aside>

      <section class="studio-preview" aria-live="polite" aria-labelledby="preview-title">
        <div class="studio-preview-top"><span class="gvt-eyebrow">Concept window</span><span data-preview-status>Ready when you are</span></div>
        <div class="studio-canvas">
          <img data-preview-image src={sampleImage} alt="Sample gaming room concept with desk, screens and warm lighting" />
          <div class="studio-canvas-scrim" aria-hidden="true"></div>
          <div class="studio-empty-message" data-empty-message><span class="studio-pulse" aria-hidden="true"></span><p id="preview-title">Your room becomes the starting point.</p><small>Choose your direction, then generate a concept to reveal the path from space to setup.</small></div>
          <div class="studio-progress" data-progress hidden><span class="studio-spinner" aria-hidden="true"></span><strong>Building the visual direction</strong><small data-progress-copy>Preserving the room and placing the first layer of gear…</small></div>
          <span class="studio-canvas-index">GVT / VISUAL CONCEPT</span>
        </div>
        <div class="studio-preview-footer"><div><span class="studio-result-label">What happens next</span><strong data-result-title>One room. A clearer decision.</strong></div><a href="#shopping-plan">See the buying plan ↓</a></div>
      </section>
    </section>

    <section class="studio-plan" id="shopping-plan" aria-labelledby="plan-title">
      <div class="studio-plan-heading"><p class="gvt-eyebrow">From concept to cart</p><h2 id="plan-title">A pretty render is only<br /><em>the first decision.</em></h2><p>Once you choose a direction, GVT turns it into a practical route through products, comparisons and optional kits.</p></div>
      <div class="studio-plan-grid">
        <article><span>01</span><h3>We identify the jobs</h3><p>Display, comfort, sound, lighting, storage, training or work — the room gets a purpose before it gets clutter.</p></article>
        <article><span>02</span><h3>We match real gear</h3><p>Product cards stay factual. Specs, drawbacks, scores and retailer routes come from the GVT comparison catalogue.</p></article>
        <article><span>03</span><h3>You choose the route</h3><p>Buy items separately, use a decided kit, or compare alternatives when the first choice is not right for you.</p></article>
      </div>
      <div class="studio-links"><a href="/kits/gaming-room-build-kit/">Explore the gaming room kit ↗</a><a href="/gaming/">Open the comparison engine ↗</a></div>
    </section>

    <p class="studio-legal">AI concept visualisation: furniture, products, dimensions and finishes may not be exact. Confirm fit, availability and specifications with the retailer before buying.</p>
  </main>
</BaseLayout>

<script>
  const form = document.querySelector<HTMLFormElement>('#studio-form');
  const imageInput = document.querySelector<HTMLInputElement>('#studio-image');
  const image = document.querySelector<HTMLImageElement>('[data-preview-image]');
  const status = document.querySelector<HTMLElement>('[data-preview-status]');
  const progress = document.querySelector<HTMLElement>('[data-progress]');
  const progressCopy = document.querySelector<HTMLElement>('[data-progress-copy]');
  const emptyMessage = document.querySelector<HTMLElement>('[data-empty-message]');
  const submitLabel = document.querySelector<HTMLElement>('[data-submit-label]');
  const resultTitle = document.querySelector<HTMLElement>('[data-result-title]');
  const sampleImage = '/images/kits/gaming-room-build-kit.png';

  const setSelected = (selector: string) => document.querySelectorAll<HTMLElement>(selector).forEach((item) => {
    const input = item.querySelector<HTMLInputElement>('input');
    item.classList.toggle('is-selected', Boolean(input?.checked));
  });
  document.querySelectorAll<HTMLInputElement>('input[type="radio"]').forEach((input) => input.addEventListener('change', () => { setSelected('.studio-choice'); setSelected('.studio-mode'); }));
  document.querySelector('[data-use-sample]')?.addEventListener('click', () => { if (image) image.src = sampleImage; if (status) status.textContent = 'Sample room loaded'; });
  imageInput?.addEventListener('change', () => {
    const file = imageInput.files?.[0];
    if (!file || !image) return;
    if (file.size > 8 * 1024 * 1024) { imageInput.value = ''; if (status) status.textContent = 'That image is over 8MB'; return; }
    image.src = URL.createObjectURL(file); if (status) status.textContent = 'Photo ready to transform';
  });
  const readAsDataUrl = (file: File) => new Promise<string>((resolve, reject) => { const reader = new FileReader(); reader.onload = () => resolve(String(reader.result)); reader.onerror = () => reject(reader.error); reader.readAsDataURL(file); });
  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const data = new FormData(form); const file = imageInput?.files?.[0];
    if (progress) progress.hidden = false; if (emptyMessage) emptyMessage.hidden = true; if (submitLabel) submitLabel.textContent = 'Generating…'; if (status) status.textContent = 'Rendering your direction';
    form.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | HTMLButtonElement>('input, select, textarea, button').forEach((control) => { control.disabled = true; });
    try {
      const response = await fetch('/api/studio/generate', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ space: data.get('space'), mode: data.get('mode'), style: data.get('style'), budget: data.get('budget'), instructions: data.get('instructions'), image: file ? await readAsDataUrl(file) : undefined }) });
      let result = await response.json();
      if (!response.ok && response.status !== 202 && !result.demo) throw new Error(result.error || 'The studio could not generate this concept.');
      if (response.status === 202 && result.predictionId) {
        for (let attempt = 0; attempt < 30; attempt += 1) {
          await new Promise((resolve) => setTimeout(resolve, 2000));
          const poll = await fetch(`/api/studio/generate?id=${encodeURIComponent(result.predictionId)}`);
          result = await poll.json();
          if (poll.ok && result.imageUrl) break;
          if (poll.status >= 400) throw new Error(result.error || 'The studio could not finish this concept.');
          if (progressCopy) progressCopy.textContent = `Still rendering… ${attempt + 1}/30`;
        }
      }
      if (!result.imageUrl && !result.demo) throw new Error('The concept took too long to finish. Try again.');
      if (image && result.imageUrl) image.src = result.imageUrl;
      if (status) status.textContent = result.demo ? 'Preview mode · Replicate is not configured yet' : 'Concept ready';
      if (resultTitle) resultTitle.textContent = result.demo ? 'Connect Replicate to render your room.' : 'Your visual direction is ready.';
      if (progressCopy && result.demo) progressCopy.textContent = 'This is the live interface preview. Add REPLICATE_API_TOKEN in Netlify to enable generation.';
    } catch (error) { if (status) status.textContent = error instanceof Error ? error.message : 'Generation failed'; if (progressCopy) progressCopy.textContent = 'Try again with a different photo or direction.'; }
    finally { if (progress) progress.hidden = true; if (submitLabel) submitLabel.textContent = 'Generate my concept'; form.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | HTMLButtonElement>('input, select, textarea, button').forEach((control) => { control.disabled = false; }); }
  });
</script>

<style>
  .studio-page { max-width: 1320px; margin: 0 auto; padding: 2.5rem 2rem 4rem; }
  .studio-intro { display: grid; grid-template-columns: 1.05fr .7fr; gap: 4rem; align-items: end; padding: 5rem 0 3.5rem; border-bottom: 1px solid var(--border); }
  .studio-intro h1 { margin-top: .8rem; font-size: clamp(3.5rem, 8vw, 7.5rem); line-height: .86; letter-spacing: -.09em; }
  .studio-intro h1 em, .studio-plan h2 em { color: var(--accent); font-style: normal; }
  .studio-intro-copy { max-width: 35ch; padding-bottom: .3rem; }
  .studio-intro-copy p { color: var(--text); font: 1.2rem/1.4 var(--font-display); }
  .studio-intro-rule { display: block; padding-top: 1rem; border-top: 1px solid var(--border); color: var(--text-muted); font: .72rem/1.5 var(--font-mono); text-transform: uppercase; }
  .studio-workbench { display: grid; grid-template-columns: minmax(330px, .7fr) minmax(0, 1.3fr); min-height: 780px; border-bottom: 1px solid var(--border); }
  .studio-controls { padding: 2.5rem 2rem 2.5rem 0; border-right: 1px solid var(--border); }
  .studio-step { display: flex; gap: .75rem; align-items: center; margin-bottom: 1.4rem; color: var(--text); font: .78rem var(--font-mono); text-transform: uppercase; }
  .studio-step span { color: var(--accent); }
  .studio-step-spaced { margin-top: 2rem; }
  fieldset { border: 0; padding: 0; }
  legend { margin-bottom: .75rem; color: var(--text-muted); font-size: .82rem; }
  .studio-choice-grid, .studio-mode-list { display: grid; gap: .5rem; }
  .studio-choice, .studio-mode { position: relative; display: flex; gap: .8rem; align-items: flex-start; border: 1px solid var(--border); padding: .85rem; cursor: pointer; transition: border-color .2s ease, background .2s ease; }
  .studio-choice:hover, .studio-mode:hover, .studio-choice.is-selected, .studio-mode.is-selected { border-color: var(--accent); background: var(--accent-dim); }
  .studio-choice input, .studio-mode input { position: absolute; opacity: 0; }
  .studio-choice span, .studio-mode span { display: grid; gap: .25rem; }
  .studio-choice strong, .studio-mode strong { color: var(--text); font: .88rem var(--font-display); }
  .studio-choice small, .studio-mode small { color: var(--text-muted); font-size: .75rem; line-height: 1.35; }
  .studio-mode { display: grid; grid-template-columns: 1fr auto; }
  .studio-mode i { color: var(--accent); font: .68rem var(--font-mono); font-style: normal; }
  .studio-field-row { display: grid; grid-template-columns: 1fr 1fr; gap: .6rem; margin-top: 1.3rem; }
  .studio-field { display: grid; gap: .45rem; margin-top: 1.1rem; color: var(--text-muted); font: .68rem var(--font-mono); text-transform: uppercase; }
  .studio-field select, .studio-field textarea { width: 100%; border: 1px solid var(--border); border-radius: 0; padding: .75rem; color: var(--text); background: var(--surface); font: .85rem var(--font); text-transform: none; }
  .studio-field textarea { resize: vertical; line-height: 1.45; }
  .studio-field select:focus, .studio-field textarea:focus, .studio-upload-label:focus-within { outline: 2px solid var(--accent); outline-offset: 2px; }
  .studio-upload { margin-top: 1.4rem; border-top: 1px solid var(--border); padding-top: 1.2rem; }
  .studio-upload-label { display: flex; gap: .8rem; align-items: center; cursor: pointer; }
  .studio-upload-label strong, .studio-upload-label small { display: block; }
  .studio-upload-label strong { color: var(--text); font: .85rem var(--font-display); }
  .studio-upload-label small { margin-top: .2rem; color: var(--text-muted); font-size: .72rem; }
  .studio-upload-icon { display: grid; width: 2.4rem; height: 2.4rem; place-items: center; border: 1px solid var(--accent); color: var(--accent); font: 1.3rem var(--font-mono); }
  .studio-upload input { position: absolute; width: 1px; height: 1px; opacity: 0; }
  .studio-sample { margin-top: .6rem; border: 0; padding: 0; color: var(--accent); background: transparent; cursor: pointer; font: .7rem var(--font-mono); }
  .studio-submit { display: flex; justify-content: space-between; width: 100%; margin-top: 1.5rem; border: 1px solid var(--accent); padding: .9rem 1rem; color: var(--ink); background: var(--accent); cursor: pointer; font: .85rem var(--font-display); font-weight: 700; }
  .studio-submit:disabled { cursor: wait; opacity: .6; }
  .studio-form-note { margin-top: .7rem; color: var(--text-muted); font-size: .72rem; line-height: 1.4; }
  .studio-preview { min-width: 0; padding: 2.5rem 0 2.5rem 2rem; }
  .studio-preview-top, .studio-preview-footer { display: flex; justify-content: space-between; gap: 1rem; align-items: center; }
  .studio-preview-top { margin-bottom: 1rem; color: var(--text-muted); font: .68rem var(--font-mono); text-transform: uppercase; }
  .studio-canvas { position: relative; min-height: 640px; overflow: hidden; background: var(--surface-2); }
  .studio-canvas > img { width: 100%; height: 640px; object-fit: cover; }
  .studio-canvas-scrim { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(7,9,11,.08), rgba(7,9,11,.72)); pointer-events: none; }
  .studio-empty-message, .studio-progress { position: absolute; right: 2rem; bottom: 2rem; left: 2rem; max-width: 28rem; }
  .studio-empty-message p { margin: .8rem 0 .35rem; color: var(--text); font: 1.35rem var(--font-display); }
  .studio-empty-message small, .studio-progress small { color: var(--text-secondary); font-size: .85rem; }
  .studio-pulse, .studio-spinner { display: block; width: .7rem; height: .7rem; border: 1px solid var(--accent); border-radius: 50%; background: var(--accent); box-shadow: 0 0 0 .35rem rgba(229,163,24,.16); }
  .studio-progress { display: grid; gap: .7rem; padding: 1rem; border: 1px solid var(--accent); background: rgba(12,15,18,.88); }
  .studio-progress strong { color: var(--text); font: 1rem var(--font-display); }
  .studio-spinner { animation: studio-spin 1s linear infinite; }
  .studio-canvas-index { position: absolute; top: 1rem; left: 1rem; color: rgba(255,255,255,.78); font: .65rem var(--font-mono); letter-spacing: .08em; }
  .studio-preview-footer { padding-top: 1rem; }
  .studio-result-label { display: block; margin-bottom: .3rem; color: var(--accent); font: .65rem var(--font-mono); text-transform: uppercase; }
  .studio-preview-footer strong { color: var(--text); font: 1rem var(--font-display); }
  .studio-preview-footer a, .studio-links a { color: var(--accent); font: .75rem var(--font-mono); }
  .studio-plan { display: grid; grid-template-columns: .8fr 1.2fr; gap: 4rem; padding: 5rem 0 2.5rem; }
  .studio-plan h2 { margin: .7rem 0 1rem; font-size: clamp(2.5rem, 5vw, 5rem); line-height: .9; letter-spacing: -.08em; }
  .studio-plan-heading > p:last-child { max-width: 34ch; }
  .studio-plan-grid { display: grid; gap: .8rem; }
  .studio-plan-grid article { display: grid; grid-template-columns: 2.2rem 1fr; column-gap: .8rem; border-top: 1px solid var(--border); padding: 1rem 0; }
  .studio-plan-grid article span { color: var(--accent); font: .68rem var(--font-mono); }
  .studio-plan-grid h3 { margin-bottom: .25rem; font-size: 1rem; }
  .studio-plan-grid p { grid-column: 2; margin: 0; color: var(--text-muted); font-size: .88rem; line-height: 1.5; }
  .studio-links { display: flex; flex-wrap: wrap; gap: 1rem 1.5rem; grid-column: 2; border-top: 1px solid var(--border); padding-top: 1.1rem; }
  .studio-legal { border-top: 1px solid var(--border); padding-top: 1rem; color: var(--text-muted); font: .7rem/1.5 var(--font-mono); }
  @keyframes studio-spin { to { transform: rotate(360deg); } }
  @media (max-width: 900px) { .studio-intro, .studio-workbench, .studio-plan { grid-template-columns: 1fr; gap: 2rem; } .studio-controls { padding-right: 0; border-right: 0; } .studio-preview { padding-left: 0; } .studio-plan-grid, .studio-links { grid-column: auto; } }
  @media (max-width: 600px) { .studio-page { padding: 1rem 1.25rem 3rem; } .studio-intro { padding: 3rem 0 2.5rem; } .studio-intro h1 { font-size: clamp(3.2rem, 17vw, 5rem); } .studio-workbench { min-height: 0; } .studio-canvas, .studio-canvas > img { min-height: 460px; height: 460px; } .studio-empty-message, .studio-progress { right: 1rem; bottom: 1rem; left: 1rem; } .studio-preview-footer { align-items: flex-start; flex-direction: column; } .studio-plan { padding-top: 3rem; } }
  @media (prefers-reduced-motion: reduce) { .studio-spinner { animation: none; } }
</style>
