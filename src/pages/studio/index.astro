---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import RoomPlanner from '../../components/RoomPlanner.astro';
import { resolveStudioRecommendations } from '../../lib/studio-catalog-server';

const sampleImage = '/images/kits/gaming-room-build-kit.png';
const spaces = [
  { value: 'gaming-room', label: 'Gaming room', note: 'Screens, desk depth, lighting and cable routes' },
  { value: 'man-cave', label: 'Man cave', note: 'Comfort, entertainment, storage and atmosphere' },
  { value: 'garden-office', label: 'Garden office', note: 'A productive room with power, light and comfort' },
  { value: 'shed-gym', label: 'Shed gym', note: 'Clearance, flooring, equipment and movement' },
];
const modes = [
  { value: 'style', label: 'Style this room', note: 'Preserve the architecture and change the look.' },
  { value: 'fill', label: 'Fill the space', note: 'Start with an empty or unfinished room.' },
  { value: 'reimagine', label: 'Reimagine it', note: 'Give the concept more creative freedom.' },
];
const styles = ['AI decides', 'Dark studio', 'Warm industrial', 'Clean minimal', 'Retro arcade', 'Quiet luxury', 'Natural workspace'];
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
const studioRecommendations = await resolveStudioRecommendations();
---

<BaseLayout title="GVT Studio" description="Visualise a gaming room, man cave, garden office or shed gym, then compare the real gear needed to build it.">
  <main class="studio-page">
    <section class="studio-intro" aria-labelledby="studio-title">
      <div>
        <p class="gvt-eyebrow">GVT / Studio 01</p>
        <h1 id="studio-title">See the room<br /><em>before you buy.</em></h1>
      </div>
      <div class="studio-intro-copy">
        <p>Upload your space. The AI analyses it, chooses a coherent direction, checks the result and builds the shopping path.</p>
        <span class="studio-intro-rule">No owner design review. The customer and the AI complete the journey together.</span>
        <div class="studio-autonomy" aria-label="Autonomous Studio stages"><span>Analyse</span><span>Design</span><span>Check</span><span>Match</span></div>
      </div>
    </section>

    <section class="studio-workbench" aria-label="GVT Studio room visualiser">
      <aside class="studio-controls">
        <div class="studio-step"><span>01</span><strong>Define the space</strong></div>
        <form id="studio-form">
          <fieldset>
            <legend>What are you building?</legend>
            <div class="studio-choice-grid">
              {spaces.map((space, index) => (
                <label class:list={['studio-choice', index === 0 && 'is-selected']}>
                  <input type="radio" name="space" value={space.value} checked={index === 0} />
                  <span><strong>{space.label}</strong><small>{space.note}</small></span>
                </label>
              ))}
            </div>
          </fieldset>

          <div class="studio-step studio-step-spaced"><span>02</span><strong>Choose the intervention</strong></div>
          <fieldset>
            <legend class="sr-only">AI intervention mode</legend>
            <div class="studio-mode-list">
              {modes.map((mode, index) => (
                <label class:list={['studio-mode', index === 0 && 'is-selected']}>
                  <input type="radio" name="mode" value={mode.value} checked={index === 0} />
                  <span><strong>{mode.label}</strong><small>{mode.note}</small></span>
                  <i aria-hidden="true">{String(index + 1).padStart(2, '0')}</i>
                </label>
              ))}
            </div>
          </fieldset>

          <div class="studio-field-row">
            <label class="studio-field"><span>Style direction</span><select name="style">{styles.map((style) => <option value={style}>{style}</option>)}</select></label>
            <label class="studio-field"><span>Working budget</span><select name="budget"><option value="under-500">Under £500</option><option value="500-1000">£500–£1,000</option><option value="1000-2500">£1,000–£2,500</option><option value="2500-plus">£2,500+</option></select></label>
          </div>

          <label class="studio-field"><span>Keep, remove or prioritise</span><textarea name="instructions" rows="3" maxlength="420" placeholder="Keep my window and existing desk. Prioritise comfortable long sessions and hidden cable routes."></textarea></label>

          <div class="studio-upload">
            <label class="studio-upload-label" for="studio-image"><span class="studio-upload-icon" aria-hidden="true">+</span><span><strong>Upload a photo of your space</strong><small>JPG, PNG or WebP · up to 8MB</small></span></label>
            <input id="studio-image" name="image" type="file" accept="image/jpeg,image/png,image/webp" />
            <button class="studio-sample" type="button" data-use-sample>Use the sample gaming room</button>
          </div>

          {turnstileSiteKey && <div class="studio-turnstile"><div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="dark" data-action="studio"></div></div>}

          <button class="studio-submit" type="submit"><span data-submit-label>Let AI design the room</span><span aria-hidden="true">↗</span></button>
          <p class="studio-form-note">When you start the Studio, your photo is sent to Replicate for AI analysis, concept generation and automated visual checking. GVT concepts are visual guidance, not dimensioned plans.</p>
        </form>
      </aside>

      <section class="studio-preview" aria-live="polite" aria-labelledby="preview-title">
        <div class="studio-preview-top"><span class="gvt-eyebrow">Concept window</span><span data-preview-status>Ready when you are</span></div>
        <div class="studio-canvas">
          <img data-preview-image src={sampleImage} alt="Sample gaming room concept with desk, screens and warm lighting" />
          <div class="studio-canvas-scrim" aria-hidden="true"></div>
          <div class="studio-empty-message" data-empty-message><span class="studio-pulse" aria-hidden="true"></span><p id="preview-title">Your room becomes the starting point.</p><small>Choose your direction, then generate a concept to reveal the path from space to setup.</small></div>
          <div class="studio-progress" data-progress hidden><span class="studio-spinner" aria-hidden="true"></span><strong>AI Studio is working</strong><small data-progress-copy>Reading the room, its constraints and its purpose…</small></div>
          <div class="studio-visual-picks" data-visual-picks hidden aria-label="Products matched to this concept"></div>
          <span class="studio-canvas-index">GVT / VISUAL CONCEPT</span>
        </div>
        <div class="studio-preview-footer"><div><span class="studio-result-label">What happens next</span><strong data-result-title>One room. A clearer decision.</strong></div><a href="#shopping-plan">See the buying plan ↓</a></div>
      </section>
    </section>

    <section class="studio-ai-report" data-ai-report hidden aria-labelledby="ai-report-title">
      <div class="studio-ai-report-head">
        <div><p class="gvt-eyebrow">Autonomous design report</p><h2 id="ai-report-title" data-ai-title>Your room concept</h2><p data-ai-summary></p></div>
        <div class="studio-quality"><span>AI quality gate</span><strong data-ai-score>—</strong><small data-ai-quality-copy>Awaiting visual check</small></div>
      </div>
      <div class="studio-ai-meta"><span>Direction</span><strong data-ai-style>AI selected</strong><div data-ai-palette aria-label="Concept colour palette"></div></div>
      <div class="studio-ai-columns">
        <div><h3>Keep and protect</h3><ul data-ai-preserve></ul></div>
        <div><h3>Improve automatically</h3><ul data-ai-improve></ul></div>
      </div>
      <div class="studio-shopping-output"><div><p class="gvt-eyebrow">Catalogue-safe plan</p><h3>What to compare next</h3><p>The AI defines the jobs. GVT supplies the factual products, specifications and retailer routes.</p></div><ol data-ai-products></ol></div>
    </section>

    <RoomPlanner recommendations={studioRecommendations} />

    <section class="studio-plan" id="shopping-plan" aria-labelledby="plan-title">
      <div class="studio-plan-heading"><p class="gvt-eyebrow">From concept to cart</p><h2 id="plan-title">A pretty render is only<br /><em>the first decision.</em></h2><p>Once you choose a direction, GVT turns it into a practical route through products, comparisons and optional kits.</p></div>
      <div class="studio-plan-grid">
        <article><span>01</span><h3>We identify the jobs</h3><p>Display, comfort, sound, lighting, storage, training or work — the room gets a purpose before it gets clutter.</p></article>
        <article><span>02</span><h3>We match real gear</h3><p>Product cards stay factual. Specs, drawbacks, scores and retailer routes come from the GVT comparison catalogue.</p></article>
        <article><span>03</span><h3>You choose the route</h3><p>Buy items separately, use a decided kit, or compare alternatives when the first choice is not right for you.</p></article>
      </div>
      <div class="studio-links"><a href="/kits/gaming-room-build-kit/">Explore the gaming room kit ↗</a><a href="/gaming/">Open the comparison engine ↗</a></div>
    </section>

    <p class="studio-legal">AI concept visualisation: furniture, products, dimensions and finishes may not be exact. Confirm fit, availability and specifications with the retailer before buying.</p>
  </main>
</BaseLayout>

{turnstileSiteKey && <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>}

<script>
  interface StudioPlan { title: string; style: string; summary: string; palette: string[]; preserve: string[]; improve: string[]; designPrompt: string; sourceQuality: { usable: boolean; reason: string }; recommendedSlots: string[]; shoppingPlan: { slot: string; category: string; reason: string; href: string; source: string; score: number }[]; }
  interface StudioReview { score: number; pass: boolean; summary: string; corrections: string[]; }
  const form = document.querySelector<HTMLFormElement>('#studio-form');
  const imageInput = document.querySelector<HTMLInputElement>('#studio-image');
  const image = document.querySelector<HTMLImageElement>('[data-preview-image]');
  const status = document.querySelector<HTMLElement>('[data-preview-status]');
  const progress = document.querySelector<HTMLElement>('[data-progress]');
  const progressCopy = document.querySelector<HTMLElement>('[data-progress-copy]');
  const emptyMessage = document.querySelector<HTMLElement>('[data-empty-message]');
  const submitLabel = document.querySelector<HTMLElement>('[data-submit-label]');
  const resultTitle = document.querySelector<HTMLElement>('[data-result-title]');
  const report = document.querySelector<HTMLElement>('[data-ai-report]');
  const sampleImage = '/images/kits/gaming-room-build-kit.png';

  const setSelected = (selector: string) => document.querySelectorAll<HTMLElement>(selector).forEach((item) => {
    const input = item.querySelector<HTMLInputElement>('input');
    item.classList.toggle('is-selected', Boolean(input?.checked));
  });
  document.querySelectorAll<HTMLInputElement>('input[type="radio"]').forEach((input) => input.addEventListener('change', () => { setSelected('.studio-choice'); setSelected('.studio-mode'); }));
  document.querySelector('[data-use-sample]')?.addEventListener('click', () => { if (image) image.src = sampleImage; if (status) status.textContent = 'Sample room loaded'; });
  imageInput?.addEventListener('change', () => {
    const file = imageInput.files?.[0];
    if (!file || !image) return;
    if (file.size > 8 * 1024 * 1024) { imageInput.value = ''; if (status) status.textContent = 'That image is over 8MB'; return; }
    image.src = URL.createObjectURL(file); if (status) status.textContent = 'Photo ready to transform';
  });
  const readAsDataUrl = (file: Blob) => new Promise<string>((resolve, reject) => { const reader = new FileReader(); reader.onload = () => resolve(String(reader.result)); reader.onerror = () => reject(reader.error); reader.readAsDataURL(file); });
  const prepareImage = async (file: File) => {
    const bitmap = await createImageBitmap(file);
    const scale = Math.min(1, 2048 / Math.max(bitmap.width, bitmap.height));
    const canvas = document.createElement('canvas');
    canvas.width = Math.max(1, Math.round(bitmap.width * scale)); canvas.height = Math.max(1, Math.round(bitmap.height * scale));
    const context = canvas.getContext('2d');
    if (!context) { bitmap.close(); return readAsDataUrl(file); }
    context.drawImage(bitmap, 0, 0, canvas.width, canvas.height); bitmap.close();
    const blob = await new Promise<Blob | null>((resolve) => canvas.toBlob(resolve, 'image/jpeg', .86));
    return readAsDataUrl(blob || file);
  };

  const setProgress = (headline: string, copy: string) => {
    if (status) status.textContent = headline;
    if (progressCopy) progressCopy.textContent = copy;
  };

  const requestStudio = async (action: string, payload: Record<string, unknown>, kind: string) => {
    const response = await fetch('/api/studio/generate', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action, ...payload }) });
    let result = await response.json();
    if (!response.ok && !result.demo) throw new Error(result.error || `Studio ${action} failed.`);
    if (result.demo || response.status !== 202) return result;
    const workflowToken = result.workflowToken;
    for (let attempt = 0; attempt < 30; attempt += 1) {
      await new Promise((resolve) => setTimeout(resolve, 2000));
      const query = new URLSearchParams({ id: result.predictionId, kind: result.kind || kind, space: String(payload.space || ''), style: String(payload.style || '') });
      const poll = await fetch(`/api/studio/generate?${query}`);
      result = await poll.json();
      if (poll.ok && poll.status !== 202) return { ...result, workflowToken };
      if (poll.status >= 400) throw new Error(result.error || `Studio ${action} failed.`);
      if (progressCopy) progressCopy.textContent = `AI is still working… ${attempt + 1}/30`;
    }
    throw new Error('The AI took too long to finish. Try again.');
  };

  const fillList = (selector: string, values: string[]) => {
    const target = document.querySelector<HTMLElement>(selector);
    if (!target) return;
    target.replaceChildren(...(values.length ? values : ['No change required.']).map((value) => { const item = document.createElement('li'); item.textContent = value; return item; }));
  };

  const renderReport = (plan: StudioPlan, review: StudioReview | null, demo: boolean) => {
    const title = document.querySelector<HTMLElement>('[data-ai-title]');
    const summary = document.querySelector<HTMLElement>('[data-ai-summary]');
    const style = document.querySelector<HTMLElement>('[data-ai-style]');
    const score = document.querySelector<HTMLElement>('[data-ai-score]');
    const quality = document.querySelector<HTMLElement>('[data-ai-quality-copy]');
    const palette = document.querySelector<HTMLElement>('[data-ai-palette]');
    const products = document.querySelector<HTMLElement>('[data-ai-products]');
    const visualPicks = document.querySelector<HTMLElement>('[data-visual-picks]');
    if (title) title.textContent = plan.title;
    if (summary) summary.textContent = plan.summary;
    if (style) style.textContent = plan.style;
    if (score) score.textContent = demo ? 'Preview' : (review?.pass ? 'Verified' : 'Rejected');
    if (quality) quality.textContent = demo ? 'Connect Replicate for autonomous checking' : (review?.summary || 'Visual check complete');
    if (palette) palette.replaceChildren(...plan.palette.map((colour) => { const swatch = document.createElement('span'); swatch.style.backgroundColor = colour; swatch.title = colour; swatch.setAttribute('aria-label', colour); return swatch; }));
    fillList('[data-ai-preserve]', plan.preserve);
    fillList('[data-ai-improve]', plan.improve);
    if (products) products.replaceChildren(...plan.shoppingPlan.map((product, index) => {
      const item = document.createElement('li'); const link = document.createElement('a'); const number = document.createElement('span'); const copy = document.createElement('span'); const name = document.createElement('strong'); const reason = document.createElement('small');
      number.textContent = String(index + 1).padStart(2, '0'); name.textContent = product.category; reason.textContent = product.reason; copy.append(name, reason); link.href = product.href; link.append(number, copy); item.append(link); return item;
    }));
    if (visualPicks) {
      visualPicks.replaceChildren(...plan.shoppingPlan.map((product, index) => { const link = document.createElement('a'); const number = document.createElement('span'); const copy = document.createElement('span'); number.textContent = String(index + 1).padStart(2, '0'); copy.textContent = product.category; link.href = product.href; link.title = `${product.source} · ${product.score}/10`; link.append(number, copy); return link; }));
      visualPicks.hidden = false;
    }
    if (report) report.hidden = false;
  };

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const data = new FormData(form); const file = imageInput?.files?.[0];
    const sourceImage = file ? await prepareImage(file) : undefined;
    const payload = { space: data.get('space'), mode: data.get('mode'), style: data.get('style'), budget: data.get('budget'), instructions: data.get('instructions'), image: sourceImage, turnstileToken: data.get('cf-turnstile-response') };
    if (progress) progress.hidden = false; if (emptyMessage) emptyMessage.hidden = true; if (report) report.hidden = true; const visualPicks = document.querySelector<HTMLElement>('[data-visual-picks]'); if (visualPicks) visualPicks.hidden = true; if (submitLabel) submitLabel.textContent = 'AI is designing…';
    form.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | HTMLButtonElement>('input, select, textarea, button').forEach((control) => { control.disabled = true; });
    try {
      setProgress('AI is analysing the room', 'Reading fixed architecture, circulation, light and practical constraints…');
      const analysis = await requestStudio('analyse', payload, 'plan');
      const plan = analysis.plan as StudioPlan;
      if (plan?.sourceQuality?.usable === false) throw new Error(plan.sourceQuality.reason || 'Use a clear photograph showing the room walls and floor.');
      if (!plan?.designPrompt) throw new Error('The AI room analysis returned an incomplete design brief. Try again.');
      const protectedPayload = { ...payload, turnstileToken: undefined, workflowToken: analysis.workflowToken };
      setProgress('AI is designing the room', 'Turning the design brief into a believable visual concept…');
      let generation = await requestStudio('generate', { ...protectedPayload, designBrief: plan.designPrompt }, 'image');
      let review: StudioReview | null = null;
      if (!generation.demo) {
        setProgress('AI is checking its work', 'Testing perspective, scale, room preservation and usability…');
        const check = await requestStudio('review', { ...protectedPayload, resultImage: generation.imageUrl, designBrief: plan.designPrompt, preserve: plan.preserve }, 'review');
        review = check.review as StudioReview;
        if (!review.pass) {
          setProgress('AI is correcting the concept', 'The first result missed the quality threshold. Applying the visual review automatically…');
          generation = await requestStudio('generate', { ...protectedPayload, designBrief: plan.designPrompt, correction: review.corrections.join('. ') }, 'image');
          setProgress('AI is verifying the correction', 'Running the final independent visual check…');
          const finalCheck = await requestStudio('review', { ...protectedPayload, resultImage: generation.imageUrl, designBrief: plan.designPrompt, preserve: plan.preserve }, 'review');
          review = finalCheck.review as StudioReview;
        }
        if (!review?.pass) throw new Error(`The Studio could not preserve this room reliably. ${review?.summary || 'Try a clearer, wider photo.'}`);
      }
      if (image && generation.imageUrl) image.src = generation.imageUrl;
      if (status) status.textContent = generation.demo ? 'Preview mode · Replicate is not configured yet' : 'AI concept and quality check complete';
      if (resultTitle) resultTitle.textContent = generation.demo ? 'Connect Replicate to run the autonomous Studio.' : 'AI-selected direction · visual check passed';
      renderReport(plan, review, Boolean(generation.demo));
      document.dispatchEvent(new CustomEvent('gvt:studio-plan', { detail: { space: payload.space, plan } }));
    } catch (error) { if (status) status.textContent = error instanceof Error ? error.message : 'Generation failed'; if (progressCopy) progressCopy.textContent = 'Try again with a different photo or direction.'; }
    finally { if (progress) progress.hidden = true; if (submitLabel) submitLabel.textContent = 'Let AI design the room'; form.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | HTMLButtonElement>('input, select, textarea, button').forEach((control) => { control.disabled = false; }); (window as Window & { turnstile?: { reset: () => void } }).turnstile?.reset(); }
  });
</script>

<style>
  .studio-page { max-width: 1320px; margin: 0 auto; padding: 2.5rem 2rem 4rem; }
  .studio-intro { display: grid; grid-template-columns: 1.05fr .7fr; gap: 4rem; align-items: end; padding: 5rem 0 3.5rem; border-bottom: 1px solid var(--border); }
  .studio-intro h1 { margin-top: .8rem; font-size: clamp(3.5rem, 8vw, 7.5rem); line-height: .86; letter-spacing: -.09em; }
  .studio-intro h1 em, .studio-plan h2 em { color: var(--accent); font-style: normal; }
  .studio-intro-copy { max-width: 35ch; padding-bottom: .3rem; }
  .studio-intro-copy p { color: var(--text); font: 1.2rem/1.4 var(--font-display); }
  .studio-intro-rule { display: block; padding-top: 1rem; border-top: 1px solid var(--border); color: var(--text-muted); font: .72rem/1.5 var(--font-mono); text-transform: uppercase; }
  .studio-autonomy { display: flex; flex-wrap: wrap; gap: .4rem; margin-top: 1rem; }
  .studio-autonomy span { border: 1px solid var(--border); padding: .28rem .48rem; color: var(--accent); font: .62rem var(--font-mono); text-transform: uppercase; }
  .studio-workbench { display: grid; grid-template-columns: minmax(330px, .7fr) minmax(0, 1.3fr); min-height: 780px; border-bottom: 1px solid var(--border); }
  .studio-controls { padding: 2.5rem 2rem 2.5rem 0; border-right: 1px solid var(--border); }
  .studio-step { display: flex; gap: .75rem; align-items: center; margin-bottom: 1.4rem; color: var(--text); font: .78rem var(--font-mono); text-transform: uppercase; }
  .studio-step span { color: var(--accent); }
  .studio-step-spaced { margin-top: 2rem; }
  fieldset { border: 0; padding: 0; }
  legend { margin-bottom: .75rem; color: var(--text-muted); font-size: .82rem; }
  .studio-choice-grid, .studio-mode-list { display: grid; gap: .5rem; }
  .studio-choice, .studio-mode { position: relative; display: flex; gap: .8rem; align-items: flex-start; border: 1px solid var(--border); padding: .85rem; cursor: pointer; transition: border-color .2s ease, background .2s ease; }
  .studio-choice:hover, .studio-mode:hover, .studio-choice.is-selected, .studio-mode.is-selected { border-color: var(--accent); background: var(--accent-dim); }
  .studio-choice input, .studio-mode input { position: absolute; opacity: 0; }
  .studio-choice span, .studio-mode span { display: grid; gap: .25rem; }
  .studio-choice strong, .studio-mode strong { color: var(--text); font: .88rem var(--font-display); }
  .studio-choice small, .studio-mode small { color: var(--text-muted); font-size: .75rem; line-height: 1.35; }
  .studio-mode { display: grid; grid-template-columns: 1fr auto; }
  .studio-mode i { color: var(--accent); font: .68rem var(--font-mono); font-style: normal; }
  .studio-field-row { display: grid; grid-template-columns: 1fr 1fr; gap: .6rem; margin-top: 1.3rem; }
  .studio-field { display: grid; gap: .45rem; margin-top: 1.1rem; color: var(--text-muted); font: .68rem var(--font-mono); text-transform: uppercase; }
  .studio-field select, .studio-field textarea { width: 100%; border: 1px solid var(--border); border-radius: 0; padding: .75rem; color: var(--text); background: var(--surface); font: .85rem var(--font); text-transform: none; }
  .studio-field textarea { resize: vertical; line-height: 1.45; }
  .studio-field select:focus, .studio-field textarea:focus, .studio-upload-label:focus-within { outline: 2px solid var(--accent); outline-offset: 2px; }
  .studio-upload { margin-top: 1.4rem; border-top: 1px solid var(--border); padding-top: 1.2rem; }
  .studio-upload-label { display: flex; gap: .8rem; align-items: center; cursor: pointer; }
  .studio-upload-label strong, .studio-upload-label small { display: block; }
  .studio-upload-label strong { color: var(--text); font: .85rem var(--font-display); }
  .studio-upload-label small { margin-top: .2rem; color: var(--text-muted); font-size: .72rem; }
  .studio-upload-icon { display: grid; width: 2.4rem; height: 2.4rem; place-items: center; border: 1px solid var(--accent); color: var(--accent); font: 1.3rem var(--font-mono); }
  .studio-upload input { position: absolute; width: 1px; height: 1px; opacity: 0; }
  .studio-sample { margin-top: .6rem; border: 0; padding: 0; color: var(--accent); background: transparent; cursor: pointer; font: .7rem var(--font-mono); }
  .studio-turnstile { margin-top: 1rem; min-height: 65px; }
  .studio-submit { display: flex; justify-content: space-between; width: 100%; margin-top: 1.5rem; border: 1px solid var(--accent); padding: .9rem 1rem; color: var(--ink); background: var(--accent); cursor: pointer; font: .85rem var(--font-display); font-weight: 700; }
  .studio-submit:disabled { cursor: wait; opacity: .6; }
  .studio-form-note { margin-top: .7rem; color: var(--text-muted); font-size: .72rem; line-height: 1.4; }
