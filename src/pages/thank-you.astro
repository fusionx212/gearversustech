---
import BaseLayout from '../layouts/BaseLayout.astro';
import KitCTA from '../components/KitCTA.astro';
---

<BaseLayout
  title="You're on the list"
  description="Thanks for subscribing to Gear Versus Tech — new compares and kit drops, one email a week."
>

<section class="hub-hero">
  <div class="container" style="text-align:center;max-width:36rem;margin:0 auto;">
    <p class="band-kicker" style="color:var(--accent);font-family:var(--font-display);font-size:0.75rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:0.5rem;">Subscribed</p>
    <h1>You're on the list.</h1>
    <p>Thanks — you’re confirmed. Expect one email a week: new versus matchups, UK stock notes, and kit drops. No daily spam, unsubscribe any time.</p>
    <p style="color:var(--text-muted);font-size:0.9rem;">If nothing arrives in a few minutes, check spam/promotions for mail from Netlify Forms / Gear Versus Tech.</p>
    <div class="hero-cta" style="justify-content:center;margin-top:1.25rem;">
      <a class="btn btn-kit" href="/gaming/">Gaming compares</a>
      <a class="btn btn-ghost" href="/home-gym/">Home gym compares</a>
    </div>
  </div>
</section>

<div class="container">
  <KitCTA
    title="Want the cart decided now?"
    blurb="Grab a build kit while you wait for the next email — UK lists, budget tiers, layout notes."
  />
</div>

</BaseLayout>
