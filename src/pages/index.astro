---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLatestArticles } from '../lib/supabase';

const articles = await getLatestArticles(12);

const CATEGORY_LABELS: Record<string, string> = {
  'smart-home': 'Smart Home',
  'gaming': 'Gaming',
  'best': 'Best in Class',
};
---

<BaseLayout
  title="Gear Versus Tech"
  description="Authoritative product comparisons for smart home automation and gaming gear. Cost, problems, versus matchups, reviews, and best-in-class picks."
>

<div class="container">
  <section class="hero">
    <div class="hero-badge">Independent Comparisons</div>
    <h1>We Compare. You Choose. Buy Smarter.</h1>
    <p>Authoritative head-to-head comparisons across Smart Home and Gaming. Cost breakdowns, honest drawbacks, and data-backed verdicts. No sponsored rankings.</p>
  </section>

  <div class="grid-2">
    <a href="/smart-home/" class="card">
      <div class="card-cat">Smart Home</div>
      <div class="card-title">Smart Home Comparisons</div>
      <div class="card-desc">Hubs, sensors, lights, locks, thermostats. Matter, Zigbee, Z-Wave, Thread -- tested and compared.</div>
    </a>
    <a href="/gaming/" class="card">
      <div class="card-cat">Gaming</div>
      <div class="card-title">Gaming Gear Comparisons</div>
      <div class="card-desc">Desks, chairs, monitors, keyboards, mice, headsets. Competitive analysis for every setup.</div>
    </a>
  </div>

  {articles.length > 0 && (
    <>
      <div class="section-label"><span>Latest Comparisons</span><span class="count">New</span></div>
      <div class="grid-2">
        {articles.slice(0, 8).map(a => (
          <a href={`/${a.category}/compare/${a.slug}/`} class="card">
            <div class="card-cat">{a.subcategory || CATEGORY_LABELS[a.category]}</div>
            <div class="card-title">{a.title}</div>
            <div class="card-desc">{a.description}</div>
            <div class="card-meta">
              {a.winner_name && <span class="winner">Winner: {a.winner_name}</span>}
              {a.winner_rating && <span class="rating">{a.winner_rating}</span>}
            </div>
          </a>
        ))}
      </div>
    </>
  )}
</div>

</BaseLayout>
