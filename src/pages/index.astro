---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import KitCTA from '../components/KitCTA.astro';
import EmailCapture from '../components/EmailCapture.astro';
import { getLatestArticles, attachWinnerImages } from '../lib/supabase';

/** Garden shed / outdoor-setup compares — keep out of the in-home #latest wall. */
function isGardenShedArticle(a: {
  slug: string;
  title: string;
  subcategory?: string | null;
}): boolean {
  const sub = (a.subcategory || '').toLowerCase();
  if (sub.includes('garden shed') || sub === 'sheds') return true;
  return /shed|garden[\s-]?office|summerhouse|summer[\s-]?house|man[\s-]?cave|desk[\s-]?size/i.test(
    `${a.slug} ${a.title}`
  );
}

const articlesRaw = await getLatestArticles(40);
const articles = await attachWinnerImages(articlesRaw);

const gearArticles = articles.filter((a) => !isGardenShedArticle(a));
const gardenArticles = articles.filter((a) => isGardenShedArticle(a));

// Featured: prefer in-home/gear so garden doesn't own the hero slot
const featured =
  gearArticles.find((a) => a.winnerImage) ||
  gearArticles[0] ||
  articles.find((a) => a.winnerImage) ||
  articles[0] ||
  null;

const listArticles = featured
  ? gearArticles.filter((a) => a.slug !== featured.slug).slice(0, 10)
  : gearArticles.slice(0, 10);

const gardenList = featured
  ? gardenArticles.filter((a) => a.slug !== featured.slug).slice(0, 8)
  : gardenArticles.slice(0, 8);

const CATEGORY_LABELS: Record<string, string> = {
  'smart-home': 'Smart Home',
  gaming: 'Gaming',
  'home-gym': 'Home Gym',
  best: 'Best in Class',
};

const CATEGORIES = [
  { href: '/gaming/', label: 'Gaming compares', note: 'Monitors, chairs, keyboards, headsets' },
  { href: '/smart-home/', label: 'Smart home', note: 'Hubs, lights, locks, sensors' },
  { href: '/home-gym/', label: 'Home gym', note: 'Racks, flooring, cardio, free weights' },
  { href: '/best/garden-sheds/', label: 'Garden sheds', note: 'Offices, gyms, man caves outdoors' },
];

const INTENTS = [
  { href: '/gaming/', label: 'X vs Y' },
  { href: '/best/', label: 'Best under £X' },
  { href: '/smart-home/', label: 'Smart home stacks' },
  { href: '/best/garden-sheds/', label: 'Garden shed setups' },
];

const PACKS = [
  {
    href: '/kits/gaming-room-build-kit/',
    kicker: 'In-home pack',
    title: 'Gaming Room kit',
    note: 'Desk, chair, lighting — decided cart for indoor setups.',
  },
  {
    href: '/best/garden-sheds/',
    kicker: 'Garden shed setups',
    title: 'Outdoor fitting hub',
    note: 'Summer house, garden office, man cave, shed gym — then the pack.',
  },
];
---

<BaseLayout
  title="Gear Versus Tech"
  description="UK tech comparison engine — X vs Y and best-under-£X picks with scores, drawbacks, and live Amazon/eBay buy boxes."
>

<section class="home-hero">
  <div class="home-hero-inner">
    <p class="home-hero-brand">Gear<span>Versus</span>Tech</p>
    <h1>Find the right product. Compare first.</h1>
    <p class="lede">
      UK gear comparisons with clear winners, who should skip, and live prices — so you buy once, not after ten more tabs.
    </p>
    <div class="hero-cta">
      <a class="btn btn-kit" href="#latest">Latest compares</a>
      <a class="btn btn-ghost" href="#garden-sheds">Garden sheds</a>
    </div>
    <nav class="intent-rail" aria-label="How to browse">
      {INTENTS.map((i) => (
        <a href={i.href} class="intent-chip">{i.label}</a>
      ))}
    </nav>
  </div>
</section>

<nav class="cat-path" aria-label="Comparison categories">
  <div class="cat-path-inner">
    {CATEGORIES.map((c) => (
      <a href={c.href} class="cat-path-link">
        <span class="cat-path-label">{c.label}</span>
        <span class="cat-path-note">{c.note}</span>
      </a>
    ))}
  </div>
</nav>

{featured && (
  <section class="featured-compare" id="featured">
    <div class="featured-compare-inner">
      <div class="section-label"><span>Featured compare</span></div>
      <a href={`/${featured.category}/compare/${featured.slug}/`} class="featured-compare-link">
        <div class="featured-compare-stage">
          {featured.winnerImage ? (
            <img src={featured.winnerImage} alt="" loading="eager" />
          ) : (
            <span class="thumb-empty">No photo</span>
          )}
        </div>
        <div class="featured-compare-copy">
          <div class="card-cat">{featured.subcategory || CATEGORY_LABELS[featured.category]}</div>
          <h2>{featured.title}</h2>
          <p>{featured.description}</p>
          {(featured.winner_name || featured.winner_rating) && (
            <p class="featured-meta">
              {featured.winner_name && <span class="winner">Our pick: {featured.winner_name}</span>}
              {featured.winner_rating && <span class="rating">{featured.winner_rating}/10</span>}
            </p>
          )}
          <span class="featured-cta">See verdict &amp; buy boxes →</span>
        </div>
      </a>
    </div>
  </section>
)}

<section class="pack-strip" id="packs" aria-label="Setup packs">
  <div class="pack-strip-inner">
    {PACKS.map((p) => (
      <a href={p.href} class="pack-strip-card">
        <span class="pack-strip-kicker">{p.kicker}</span>
        <strong class="pack-strip-title">{p.title}</strong>
        <span class="pack-strip-note">{p.note}</span>
      </a>
    ))}
  </div>
</section>

{listArticles.length > 0 && (
  <section class="latest-section" id="latest">
    <div class="section-label">
      <span>Latest comparisons</span>
      <span class="count">{listArticles.length}</span>
    </div>
    <p class="section-lede">In-home gear — gaming, smart home, home gym, and best-in-class picks.</p>
    {listArticles.map((a) => (
      <a href={`/${a.category}/compare/${a.slug}/`} class="compare-row">
        <div class="compare-row-thumb">
          {a.winnerImage ? (
            <img src={a.winnerImage} alt="" loading="lazy" />
          ) : (
            <span class="thumb-empty">No photo</span>
          )}
        </div>
        <div class="compare-row-body">
          <div class="card-cat">{a.subcategory || CATEGORY_LABELS[a.category]}</div>
          <div class="card-title">{a.title}</div>
          <div class="card-desc">{a.description}</div>
        </div>
        <div class="compare-row-meta">
          {a.winner_name && <span class="winner">{a.winner_name}</span>}
          {a.winner_rating && <span class="rating">{a.winner_rating}/10</span>}
        </div>
      </a>
    ))}
  </section>
)}

{gardenList.length > 0 && (
  <section class="latest-section garden-section" id="garden-sheds">
    <div class="section-label">
      <span>Garden sheds &amp; outdoor setups</span>
      <span class="count">{gardenList.length}</span>
    </div>
    <p class="section-lede">
      Size the shell, plan power, then fit out —
      <a href="/best/garden-sheds/">full garden space hub</a>.
    </p>
    {gardenList.map((a) => (
      <a href={`/${a.category}/compare/${a.slug}/`} class="compare-row">
        <div class="compare-row-thumb">
          {a.winnerImage ? (
            <img src={a.winnerImage} alt="" loading="lazy" />
          ) : (
            <span class="thumb-empty">No photo</span>
          )}
        </div>
        <div class="compare-row-body">
          <div class="card-cat">{a.subcategory || CATEGORY_LABELS[a.category]}</div>
          <div class="card-title">{a.title}</div>
          <div class="card-desc">{a.description}</div>
        </div>
        <div class="compare-row-meta">
          {a.winner_name && <span class="winner">{a.winner_name}</span>}
          {a.winner_rating && <span class="rating">{a.winner_rating}/10</span>}
        </div>
      </a>
    ))}
    <p class="section-more">
      <a href="/best/garden-sheds/">All garden shed journeys →</a>
      {' · '}
      <a href="/kits/shed-garden-office-setup-pack/">Garden office pack</a>
      {' · '}
      <a href="/kits/shed-gym-setup-pack/">Shed gym pack</a>
    </p>
  </section>
)}

<section class="method-lite" id="how-we-pick">
  <div class="method-lite-inner">
    <div class="section-label"><span>How we pick winners</span></div>
    <div class="method-lite-grid">
      <div>
        <h3>Scores that mean something</h3>
        <p>Performance 40%, value 25%, build 20%, ease of use 15%. Out of 10 — weighted, not vibes.</p>
      </div>
      <div>
        <h3>Drawbacks first</h3>
        <p>Every compare lists who should <em>not</em> buy. If the cheaper option wins for most people, it wins.</p>
      </div>
      <div>
        <h3>Live UK buy boxes</h3>
        <p>Amazon and eBay prices at publish time. Affiliate links may earn us a cut — rankings are never sold.</p>
      </div>
    </div>
    <p class="method-lite-more"><a href="/methodology/">Full methodology →</a></p>
  </div>
</section>

<div class="container home-convert">
  <KitCTA
    title="Want the decided cart?"
    blurb="Optional build kits for when a compare is done and you just want the shopping list — not required to use the site."
    kitSlug="gaming-room-build-kit"
  />
  <EmailCapture />
</div>

</BaseLayout>
