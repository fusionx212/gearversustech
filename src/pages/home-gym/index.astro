---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import KitCTA from '../../components/KitCTA.astro';
import CategoryClusterList from '../../components/CategoryClusterList.astro';
import { getArticlesByCategory, attachWinnerImages } from '../../lib/supabase';

// Until DB CHECK allows category=home-gym, home-gym spokes live as category=best + subcategory Home Gym.
const articlesRaw = await getArticlesByCategory('best', 40);
const homeGym = articlesRaw.filter(
  (a) =>
    (a.subcategory || '').toLowerCase().includes('home gym') ||
    (a.subcategory || '').toLowerCase().includes('garage')
);
const filtered = homeGym.length
  ? homeGym
  : articlesRaw.filter((a) => /gym|rack|floor|dumbbell/i.test(a.title + (a.description || '')));
const articles = await attachWinnerImages(filtered);
---

<BaseLayout
  title="Home gym comparisons"
  description="UK garage and small-room home gym comparisons — racks, flooring, dumbbells, noise for terraces."
>

<section class="hub-hero">
  <div class="container-wide">
    <p class="hub-kicker">Home gym</p>
    <h1>Home gym comparisons</h1>
    <p>UK ceiling height, terrace noise, single-garage width. Head-to-head picks — clustered so related gear sits together.</p>
    <div class="hero-cta" style="margin-top:1rem;">
      <a class="btn btn-ghost" href="/spaces/garage-gym/">Room guide (secondary)</a>
    </div>
  </div>
</section>

<CategoryClusterList
  articles={articles}
  emptyHtml={`<p>First home-gym compares are seeding. <a href="/spaces/garage-gym/">Read the garage gym hub</a> or <a href="/gaming/">browse gaming</a>.</p>`}
/>

<div class="container">
  <KitCTA
    title="UK Garage Gym Build Kit"
    blurb="Ceiling constraints, rack/flooring picks, noise notes, and a verified UK cart."
    kitLabel="Get the Garage Gym Kit — £19"
  />
</div>
</BaseLayout>
