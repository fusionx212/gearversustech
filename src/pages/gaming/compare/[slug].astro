---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getArticle, getArticleProducts, getComparedProducts, productKey } from '../../../lib/supabase';

export const prerender = false;

const { slug } = Astro.params;
const article = await getArticle(slug as string);

if (!article) {
  return new Response('Article not found', { status: 404 });
}

const { title, description, category, subcategory, content_html, winner_name, winner_rating, runnerup_name, runnerup_rating } = article;

// Product imagery, prices and ASINs come from gvt_affiliate_links, populated from the
// Amazon Creators API by scripts/sync-amazon-products.mjs.
const { winner, runnerup } = await getArticleProducts(article);
const hasRunnerup = Boolean(runnerup_name && runnerup_rating);

// Fetch ALL compared products (beyond just winner + runner-up)
const excludeFromAlso = [winner_name, runnerup_name].filter(Boolean) as string[];
const alsoCompared = await getComparedProducts(content_html, excludeFromAlso);

const pageUrl = `https://gearversustech.com/${category}/compare/${slug}/`;

/** Product node carrying the rating and price we already show on the page — this is
 *  what earns the star rating and price in search results. */
const productNode = (name: string, rating: number | null, link: typeof winner) => ({
  '@type': 'Product',
  name,
  ...(link?.image_url ? { image: link.image_url } : {}),
  ...(link?.uk_price_gbp
    ? {
        offers: {
          '@type': 'Offer',
          price: link.uk_price_gbp,
          priceCurrency: 'GBP',
          availability: 'https://schema.org/InStock',
          url: `https://gearversustech.com/c/amazon/${link.link_key}`,
        },
      }
    : {}),
  ...(rating
    ? {
        review: {
          '@type': 'Review',
          reviewRating: { '@type': 'Rating', ratingValue: rating, bestRating: 10, worstRating: 1 },
          author: { '@type': 'Organization', name: 'Gear Versus Tech' },
        },
      }
    : {}),
});

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      headline: title,
      description,
      datePublished: article.created_at,
      dateModified: article.updated_at,
      author: { '@type': 'Organization', name: 'Gear Versus Tech' },
      publisher: { '@type': 'Organization', name: 'Gear Versus Tech', url: 'https://gearversustech.com' },
      mainEntityOfPage: pageUrl,
    },
    ...(winner_name && winner_rating ? [productNode(winner_name, winner_rating, winner)] : []),
    ...(runnerup_name && runnerup_rating ? [productNode(runnerup_name, runnerup_rating, runnerup)] : []),
  ],
});

const CATEGORY_LABELS: Record<string, string> = {
  'smart-home': 'Smart Home',
  'gaming': 'Gaming',
  'best': 'Best Picks',
};
---

<BaseLayout title={title} description={description} schema={schema}>
<div class="container">
  <nav class="breadcrumb">
    <a href="/">Home</a> / <a href={`/${category}/`}>{CATEGORY_LABELS[category]}</a> / <span class="current">{title}</span>
  </nav>

  <h1>{title}</h1>
  <p class="article-meta-line">
    Updated {new Date(article.updated_at).toLocaleDateString('en-GB', { month: 'long', day: 'numeric', year: 'numeric' })}
    <span class="sep">|</span> {subcategory}
    <span class="sep">|</span> <a href="/methodology/">How we test</a>
  </p>

  {winner_name && winner_rating && (
    <div class={`vs-compare ${hasRunnerup ? '' : 'single'}`}>
      <div class="vs-product winner">
        <div class="vs-badge">Our Pick</div>
        {winner?.image_url && (
          <div class="vs-image-wrap">
            <img class="vs-image" src={winner.image_url} alt={winner_name} loading="lazy" />
          </div>
        )}
        <h3>{winner_name}</h3>
        <div class="vs-sub">Best overall choice for most people</div>
        <div class="vs-rating">{winner_rating} / 10</div>
        {winner?.uk_price_gbp && <div class="vs-price">£{winner.uk_price_gbp}</div>}
        <div class="cta-row">
          <a class="btn btn-amazon" rel="nofollow sponsored" target="_blank" href={`/c/amazon/${winner?.link_key ?? productKey(winner_name)}`}>Amazon</a>
          <a class="btn btn-ebay" rel="nofollow sponsored" target="_blank" href={`/c/ebay/${winner?.link_key ?? productKey(winner_name)}`}>eBay</a>
        </div>
      </div>

      {hasRunnerup && (
        <>
          <div class="vs-divider">VS</div>
          <div class="vs-product runnerup">
            <div class="vs-badge">Runner-up</div>
            {runnerup?.image_url && (
              <div class="vs-image-wrap">
                <img class="vs-image" src={runnerup.image_url} alt={runnerup_name} loading="lazy" />
              </div>
            )}
            <h3>{runnerup_name}</h3>
            <div class="vs-sub">Best for buyers prioritising value</div>
            <div class="vs-rating">{runnerup_rating} / 10</div>
            {runnerup?.uk_price_gbp && <div class="vs-price">£{runnerup.uk_price_gbp}</div>}
            <div class="cta-row">
              <a class="btn btn-amazon" rel="nofollow sponsored" target="_blank" href={`/c/amazon/${runnerup?.link_key ?? productKey(runnerup_name)}`}>Amazon</a>
              <a class="btn btn-ebay" rel="nofollow sponsored" target="_blank" href={`/c/ebay/${runnerup?.link_key ?? productKey(runnerup_name)}`}>eBay</a>
            </div>
          </div>
        </>
      )}
    </div>
  )}

  <article set:html={content_html} />

  {alsoCompared.length > 0 && (
    <section class="also-compared">
      <h2>Also Compared</h2>
      <div class="also-grid">
        {alsoCompared.map((p) => (
          <div class="also-card">
            {p.image_url && (
              <div class="also-image-wrap">
                <img class="also-image" src={p.image_url} alt={p.product_name} loading="lazy" />
              </div>
            )}
            <h4>{p.product_name}</h4>
            {p.uk_price_gbp && <div class="also-price">£{p.uk_price_gbp}</div>}
            <div class="cta-row">
              <a class="btn btn-amazon btn-sm" rel="nofollow sponsored" target="_blank"
                href={p.amazon_asin
                  ? `https://www.amazon.co.uk/dp/${p.amazon_asin}?tag=gearversustech-21`
                  : `https://www.amazon.co.uk/s?k=${encodeURIComponent(p.product_name)}&tag=gearversustech-21`}>
                Amazon
              </a>
              <a class="btn btn-ebay btn-sm" rel="nofollow sponsored" target="_blank"
                href={`https://www.ebay.co.uk/sch/i.html?_nkw=${encodeURIComponent(p.product_name)}&campid=5339164583`}>
                eBay
              </a>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <hr />

  <p style="font-size:0.78rem;color:var(--text-muted);">
    Prices checked July 2026 via the Amazon Creators API and may since have changed.
    <a href="/disclosure/">Affiliate disclosure</a> · <a href="/methodology/">How we test</a>
  </p>

  <section class="related">
    <h2>Related Comparisons</h2>
    <ul class="related-list">
      <li><a href={`/${category}/`}>All {CATEGORY_LABELS[category]} comparisons</a></li>
    </ul>
  </section>
</div>
</BaseLayout>
