---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import KitCTA from '../../components/KitCTA.astro';
import CategoryClusterList from '../../components/CategoryClusterList.astro';
import { getArticlesByCategory, attachWinnerImages } from '../../lib/supabase';

const articlesRaw = await getArticlesByCategory('gaming', 40);
const articles = await attachWinnerImages(articlesRaw);
---

<BaseLayout
  title="Gaming Gear Comparisons"
  description="Head-to-head UK gaming comparisons — monitors, chairs, keyboards, mice, headsets. Clear winners and live buy boxes."
>

<section class="hub-hero">
  <div class="container-wide">
    <p class="hub-kicker">Gaming</p>
    <h1>Gaming gear comparisons</h1>
    <p>X vs Y and best-under-£Y picks for desks that actually get used. Clustered by gear type so the graph fits together.</p>
    <div class="hero-cta" style="margin-top:1rem;">
      <a class="btn btn-ghost" href="/best/">Best / under-£ picks</a>
      <a class="btn btn-ghost" href="/spaces/gaming-room/">Room guide (secondary)</a>
    </div>
  </div>
</section>

<CategoryClusterList
  articles={articles}
  emptyHtml={`<p>Gaming comparisons coming soon. <a href="/smart-home/">See Smart Home compares</a>.</p>`}
/>

<div class="container">
  <KitCTA
    title="Gaming Room Build Kit"
    blurb="Three UK budget tiers, shopping list, and cable plan — skip another weekend of tabs."
    kitLabel="Get the Gaming Room Kit — £19"
  />
</div>
</BaseLayout>
