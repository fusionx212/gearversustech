---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getArticlesByCategory } from '../../lib/supabase';

const articles = await getArticlesByCategory('gaming', 12);
---

<BaseLayout title="Gaming Gear Comparisons" description="Data-dense comparisons of gaming desks, chairs, monitors, keyboards, mice, and headsets.">
<div class="container">
  <section class="cat-header">
    <h1>Gaming Gear Comparisons</h1>
    <p>Desks, chairs, monitors, keyboards, mice, headsets. Competitive comparisons for every setup, every budget, every game.</p>
  </section>

  <div class="grid-2">
    {articles.length > 0 ? articles.map(a => (
      <a href={`/gaming/compare/${a.slug}/`} class="card">
        <div class="card-cat">{a.subcategory || 'Gaming'}</div>
        <div class="card-title">{a.title}</div>
        <div class="card-desc">{a.description}</div>
        <div class="card-meta">
          {a.winner_name && <span class="winner">Winner: {a.winner_name}</span>}
          {a.winner_rating && <span class="rating">{a.winner_rating}</span>}
        </div>
      </a>
    )) : (
      <div class="card" style="grid-column:1/-1;text-align:center;padding:3rem;">
        <p style="color:var(--text-muted);">Gaming comparisons coming soon. <a href="/smart-home/compare/homey-pro-vs-aqara-hub-m3/">See our Smart Home comparisons</a>.</p>
      </div>
    )}
  </div>
</div>
</BaseLayout>
