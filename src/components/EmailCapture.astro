---
// Email capture component for article footers
// Embeds ConvertKit or Netlify Forms inline
---

<div class="email-capture" id="email-capture">
  <style>
    .email-capture {
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.5rem;
      margin: 2rem 0;
      text-align: left;
    }
    .email-capture h3 {
      font-family: var(--font-display);
      color: var(--text);
      margin: 0 0 0.3rem;
      font-size: 1.1rem;
    }
    .email-capture p {
      color: var(--text-secondary);
      font-size: 0.87rem;
      margin-bottom: 1rem;
    }
    .email-capture form {
      display: flex;
      gap: 0.5rem;
      max-width: 420px;
    }
    .email-capture input[type="email"] {
      flex: 1;
      padding: 0.55rem 0.8rem;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      font-family: var(--font);
      font-size: 0.85rem;
      background: var(--surface);
      color: var(--text);
    }
    .email-capture input[type="email"]:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-dim);
    }
    .email-capture .btn-submit {
      background: var(--kit);
      color: var(--ink);
      border: none;
      padding: 0.55rem 1.2rem;
      border-radius: var(--radius-sm);
      font-weight: 700;
      font-size: 0.85rem;
      font-family: var(--font-display);
      cursor: pointer;
      white-space: nowrap;
      min-height: 44px;
    }
    .email-capture .privacy {
      font-size: 0.7rem;
      color: var(--text-muted);
      margin-top: 0.5rem;
    }
    @media (max-width: 480px) {
      .email-capture form { flex-direction: column; }
    }
  </style>

  <h3>Get kit drops &amp; UK stock notes</h3>
  <p>New versus matchups, garage-gym / gaming-room kit alerts, and deal notes. One email a week.</p>

  <!-- ESP: Brevo/Mailchimp keys not in estate secrets. RESEND_API_KEY exists on Netlify/master.env
       but subscribe function not shipped yet — Netlify Forms remains the capture rail. -->
  <form name="subscribe" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/thank-you/">
    <input type="hidden" name="form-name" value="subscribe" />
    <input type="hidden" name="source" value="gvt-site" />
    <p style="display:none"><label>Leave empty: <input name="bot-field" /></label></p>
    <input type="email" name="email" placeholder="your@email.com" required autocomplete="email" />
    <button type="submit" class="btn-submit">Subscribe</button>
  </form>
  <p class="privacy">One email per week. Confirmation page next. Unsubscribe any time. <a href="/privacy/">Privacy</a>.</p>
</div>
