---
interface Product { image_url?: string | null; amazon_asin?: string | null; uk_price_gbp?: number | null; }
interface Item { product_name: string; link_key: string | null; notes?: string | null; why_in_kit?: string | null; product?: Product; }
interface Props { items: Item[]; }
const { items } = Astro.props; const visibleItems = items.filter((item) => item.product_name).slice(0, 4);
const positions = [{ left: '18%', top: '64%' }, { left: '42%', top: '70%' }, { left: '62%', top: '38%' }, { left: '79%', top: '58%' }];
const imageFor = (item: Item) => item.product?.image_url || (item.link_key ? `/images/products/${item.link_key}.webp` : null);
const hrefFor = (item: Item) => item.link_key ? `/c/${item.product?.amazon_asin ? 'amazon' : 'ebay'}/${item.link_key}` : '/kits/gaming-room-build-kit/';
---

<section class="gvt-hotspot-stage" aria-labelledby="hotspot-stage-title"><div class="gvt-hotspot-header"><div><p class="gvt-eyebrow">See the setup, not just the spec</p><h2 id="hotspot-stage-title">Build this look.</h2></div><p>Tap a marker to reveal the gear behind the room. Every pick is tied to the full kit, its evidence and a live retailer route.</p></div><div class="gvt-hotspot-layout"><div class="gvt-hotspot-scene"><img src="/images/kits/gaming-room-build-kit.png" alt="Gaming room setup with desks, monitors and warm amber lighting" loading="lazy" /><div class="gvt-hotspot-scene-wash" aria-hidden="true"></div>{visibleItems.map((item, index) => <button class:list={["gvt-hotspot-marker", index === 0 && "is-active"]} style={`left:${positions[index].left};top:${positions[index].top}`} type="button" data-hotspot-marker={index} aria-label={`Show ${item.product_name}`} aria-pressed={index === 0 ? 'true' : 'false'}><span>{String(index + 1).padStart(2, '0')}</span></button>)}<span class="gvt-hotspot-scene-caption">GVT / GAMING ROOM 01</span></div><div class="gvt-hotspot-rail"><div class="gvt-hotspot-rail-top"><span class="gvt-eyebrow">The room, itemised</span><span class="gvt-hotspot-count">{String(visibleItems.length).padStart(2, '0')} picks</span></div><div class="gvt-hotspot-products">{visibleItems.map((item, index) => { const image = imageFor(item); const href = hrefFor(item); return <article class:list={["gvt-hotspot-product", index === 0 && "is-active"]} data-hotspot-card={index}><button class="gvt-hotspot-product-select" type="button" data-hotspot-select={index} aria-label={`Focus ${item.product_name}`}><span class="gvt-hotspot-product-index">{String(index + 1).padStart(2, '0')}</span><span class="gvt-hotspot-product-image">{image ? <img src={image} alt="" loading="lazy" /> : <span>GVT</span>}</span><span class="gvt-hotspot-product-copy"><strong>{item.product_name}</strong><small>{item.why_in_kit || item.notes || 'A considered part of the room build.'}</small></span><span class="gvt-hotspot-product-arrow">↗</span></button><div class="gvt-hotspot-product-actions"><a href={href} rel="nofollow sponsored">Check price</a>{item.link_key && <button type="button" data-setup-add data-setup-item={item.product_name} data-setup-price={item.product?.uk_price_gbp ?? ''} data-setup-href={href}>+ Add to setup</button>}</div></article>; })}</div><a class="gvt-hotspot-kit-link" href="/kits/gaming-room-build-kit/"><span>Open the complete gaming room kit</span><span>→</span></a></div></div></section>

<script>
  const stage = document.querySelector('.gvt-hotspot-stage'); if (stage) { const activate = (index: string) => { stage.querySelectorAll<HTMLElement>('[data-hotspot-marker]').forEach((marker) => { const active = marker.dataset.hotspotMarker === index; marker.classList.toggle('is-active', active); marker.setAttribute('aria-pressed', String(active)); }); stage.querySelectorAll<HTMLElement>('[data-hotspot-card]').forEach((card) => card.classList.toggle('is-active', card.dataset.hotspotCard === index)); }; stage.querySelectorAll<HTMLElement>('[data-hotspot-marker], [data-hotspot-select]').forEach((control) => control.addEventListener('click', () => activate(control.dataset.hotspotMarker || control.dataset.hotspotSelect || '0'))); }
</script>
