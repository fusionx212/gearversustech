<aside class="gvt-setup-tray" data-setup-tray aria-label="Your setup">
  <button class="gvt-setup-tray-toggle" type="button" data-setup-toggle aria-expanded="false"><span class="gvt-setup-tray-count" data-setup-count>0</span><span>My setup</span><span aria-hidden="true">↗</span></button>
  <div class="gvt-setup-tray-drawer" data-setup-drawer hidden><div class="gvt-setup-tray-heading"><div><p class="gvt-eyebrow">Your shortlist</p><h2>My setup</h2></div><button type="button" class="gvt-setup-tray-close" data-setup-close aria-label="Close setup tray">×</button></div><p class="gvt-setup-tray-empty" data-setup-empty>Add products as you compare. They will stay here while you browse.</p><ul class="gvt-setup-tray-list" data-setup-list></ul><div class="gvt-setup-tray-footer"><span>Estimated total</span><strong data-setup-total>£—</strong><a class="btn btn-kit" href="/kits/gaming-room-build-kit/">See room kits ↗</a></div></div>
</aside>

<script>
  const tray = document.querySelector<HTMLElement>('[data-setup-tray]');
  if (tray) {
    const key = 'gvt-setup-v1'; const toggle = tray.querySelector<HTMLButtonElement>('[data-setup-toggle]'); const drawer = tray.querySelector<HTMLElement>('[data-setup-drawer]'); const list = tray.querySelector<HTMLElement>('[data-setup-list]'); const empty = tray.querySelector<HTMLElement>('[data-setup-empty]'); const count = tray.querySelector<HTMLElement>('[data-setup-count]'); const total = tray.querySelector<HTMLElement>('[data-setup-total]');
    const esc = (value: string) => value.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c] || c);
    const read = () => { try { return JSON.parse(localStorage.getItem(key) || '[]') as { name: string; price: number | null; href: string }[]; } catch { return []; } };
    const write = (items: { name: string; price: number | null; href: string }[]) => localStorage.setItem(key, JSON.stringify(items));
    const render = () => { const items = read(); if (count) count.textContent = String(items.length); if (empty) empty.hidden = items.length > 0; if (list) list.innerHTML = items.map((item, index) => { const href = /^\/c\/(amazon|ebay)\//.test(item.href) ? item.href : '#'; const name = esc(item.name); return `<li><a href="${esc(href)}" rel="nofollow sponsored">${name}</a><small>${item.price ? `£${item.price.toFixed(2)}` : 'Price updating'}</small><button type="button" data-setup-remove="${index}" aria-label="Remove ${name}">×</button></li>`; }).join(''); if (total) { const value = items.reduce((sum, item) => sum + (item.price || 0), 0); total.textContent = value ? `£${value.toFixed(2)}` : '£—'; } };
    const open = () => { if (drawer) drawer.hidden = false; toggle?.setAttribute('aria-expanded', 'true'); tray.classList.add('is-open'); }; const close = () => { if (drawer) drawer.hidden = true; toggle?.setAttribute('aria-expanded', 'false'); tray.classList.remove('is-open'); };
    toggle?.addEventListener('click', () => tray.classList.contains('is-open') ? close() : open()); tray.querySelector('[data-setup-close]')?.addEventListener('click', close);
    document.addEventListener('click', (event) => { const target = event.target as HTMLElement; const add = target.closest<HTMLElement>('[data-setup-add]'); const remove = target.closest<HTMLElement>('[data-setup-remove]'); if (add) { const items = read(); if (!items.some((item) => item.name === add.dataset.setupItem)) { items.push({ name: add.dataset.setupItem || 'Selected product', price: add.dataset.setupPrice ? Number(add.dataset.setupPrice) : null, href: add.dataset.setupHref || '#' }); write(items); render(); open(); } } if (remove) { const items = read(); items.splice(Number(remove.dataset.setupRemove), 1); write(items); render(); } }); render();
  }
</script>
