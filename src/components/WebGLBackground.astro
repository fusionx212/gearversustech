<script>
  import * as THREE from 'three';

  class ParticleCanvas {
    private scene: THREE.Scene;
    private camera: THREE.PerspectiveCamera;
    private renderer: THREE.WebGLRenderer;
    private particles: THREE.Points;
    private grid: THREE.LineSegments;
    private animId: number = 0;
    private mouse = { x: 0, y: 0 };

    constructor(container: HTMLElement) {
      this.scene = new THREE.Scene();

      this.camera = new THREE.PerspectiveCamera(
        60,
        window.innerWidth / window.innerHeight,
        0.1,
        100,
      );
      this.camera.position.z = 15;

      this.renderer = new THREE.WebGLRenderer({
        antialias: true,
        alpha: true,
      });
      this.renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      this.renderer.setSize(window.innerWidth, window.innerHeight);
      this.renderer.setClearColor(0x000000, 0);
      container.appendChild(this.renderer.domElement);

      this.particles = this.createParticles();
      this.grid = this.createGrid();
      this.scene.add(this.particles);
      this.scene.add(this.grid);

      window.addEventListener('mousemove', this.onMouseMove);
      window.addEventListener('resize', this.onResize);
      this.animate();
    }

    private createParticles(): THREE.Points {
      const count = 600;
      const geometry = new THREE.BufferGeometry();
      const positions = new Float32Array(count * 3);
      const colors = new Float32Array(count * 3);

      for (let i = 0; i < count; i++) {
        const i3 = i * 3;
        positions[i3] = (Math.random() - 0.5) * 40;
        positions[i3 + 1] = (Math.random() - 0.5) * 25;
        positions[i3 + 2] = (Math.random() - 0.5) * 20;

        const shade = 0.3 + Math.random() * 0.4;
        colors[i3] = shade;
        colors[i3 + 1] = shade * 0.85;
        colors[i3 + 2] = shade;
      }

      geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
      geometry.setAttribute('color', new THREE.BufferAttribute(colors, 3));

      const material = new THREE.PointsMaterial({
        size: 0.04,
        vertexColors: true,
        blending: THREE.AdditiveBlending,
        depthWrite: false,
        transparent: true,
        opacity: 0.7,
      });

      return new THREE.Points(geometry, material);
    }

    private createGrid(): THREE.LineSegments {
      const size = 30;
      const divisions = 40;
      const geometry = new THREE.BufferGeometry();
      const vertices: number[] = [];
      const step = size / divisions;
      const half = size / 2;

      for (let i = 0; i <= divisions; i++) {
        const pos = -half + i * step;
        vertices.push(pos, -half, -8, pos, half, -8);
        vertices.push(-half, pos, -8, half, pos, -8);
      }

      geometry.setAttribute(
        'position',
        new THREE.Float32BufferAttribute(vertices, 3),
      );

      const material = new THREE.LineBasicMaterial({
        color: 0x1a2a3a,
        transparent: true,
        opacity: 0.25,
        depthWrite: false,
      });

      return new THREE.LineSegments(geometry, material);
    }

    private onMouseMove = (e: MouseEvent) => {
      this.mouse.x = (e.clientX / window.innerWidth) * 2 - 1;
      this.mouse.y = -(e.clientY / window.innerHeight) * 2 + 1;
    };

    private onResize = () => {
      this.camera.aspect = window.innerWidth / window.innerHeight;
      this.camera.updateProjectionMatrix();
      this.renderer.setSize(window.innerWidth, window.innerHeight);
    };

    private animate = () => {
      this.animId = requestAnimationFrame(this.animate);
      const t = performance.now() * 0.0003;

      this.particles.rotation.y += 0.0002;
      this.particles.rotation.x += 0.0001;
      this.grid.rotation.y += 0.00005;

      this.camera.position.x += (this.mouse.x * 1.5 - this.camera.position.x) * 0.02;
      this.camera.position.y += (-this.mouse.y * 0.8 - this.camera.position.y) * 0.02;
      this.camera.lookAt(0, 0, -2);

      this.renderer.render(this.scene, this.camera);
    };

    destroy() {
      cancelAnimationFrame(this.animId);
      window.removeEventListener('mousemove', this.onMouseMove);
      window.removeEventListener('resize', this.onResize);
      this.renderer.dispose();
    }
  }

  const container = document.getElementById('webgl-bg');
  if (container) {
    new ParticleCanvas(container);
  }
</script>

<div id="webgl-bg" class="webgl-bg" aria-hidden="true"></div>

<style is:global>
  .webgl-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.7;
  }
  .webgl-bg canvas {
    display: block;
  }
</style>
